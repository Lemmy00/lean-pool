import LeanPool.Polylean.Complexes.Structures.Groupoid

namespace LeanPool.Polylean

universe u vq vg

/-!
A two-complex is defined by an underlying quiver, a groupoid whose morphisms
represent path-homotopy classes of the one-complex, and a pre-functor from the
quiver to that groupoid.

The lifting principle below says the groupoid has no extra edges beyond those
generated by the quiver modulo the identifications represented by `map`.
-/

/-- A two-complex presented by a quiver and its path-homotopy groupoid. -/
class TwoComplex (V : Sort u) [Q : Quiver.{u, vq} V] [H : Groupoid.{u, vg} V] extends
    Quiver.PreFunctor Q H.toQuiver where
  /-- Lift a compatible quiver pre-functor to a groupoid functor. -/
  lift : {W : Sort u} → [G : Groupoid.{u, vg} W] →
    (F : Quiver.PreFunctor Q G.toQuiver) →
    (∀ {X Y : V} {e e' : X ⟶ Y}, map e = map e' → F.map e = F.map e') →
      Groupoid.Functor H G
  /-- The lifted functor extends the original quiver pre-functor. -/
  lift_comp : {W : Sort u} → [G : Groupoid.{u, vg} W] →
    (F : Quiver.PreFunctor Q G.toQuiver) →
    (h : ∀ {X Y : V} {e e' : X ⟶ Y}, map e = map e' → F.map e = F.map e') →
      Quiver.PreFunctor.comp ⟨obj, map⟩ (lift F h).toPreFunctor = F

end LeanPool.Polylean
