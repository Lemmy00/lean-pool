    rcases hWnonempty with ⟨y, hyfW⟩
    have hyUbig : y ∈ Ubig := Set.mem_iUnion₂.2 ⟨W, ⟨hWmemM, hyfW⟩⟩
    have hyW : y ∈ W.set := (hf W) hyfW
    exact (Set.disjoint_left.1 hDisj) hyW hyUbig
  refine ⟨M, hMpair, ?_⟩
  simpa [Ubig] using hDense

end «ZornHelpers»

