    have hM'sub : M' ⊆ M := hMmax.2 hM'S hMM'
    have hEq : M' = M := by
      exact Set.Subset.antisymm hM'sub hMM'
    have hWmemM : W ∈ M := by
      have : W ∈ M' := Or.inr (by simp)
      simpa [hEq] using this
