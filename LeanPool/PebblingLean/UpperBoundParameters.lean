    (hcoreNineCutoff :
      81 ≤ (4 : ℝ) ^ 2 * (((3 : ℝ) * (n0 : ℝ) / 4) *
        Real.log (n0 : ℝ)))
    (hwidthConstCutoff :
      Real.log 128 + 4 * Real.log 2 ≤
        ((217 : ℝ) / 30 * Real.log 2) *
          Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ)))
    (hstackLogThreshold :
      (32 / stackMargin ^ 2) ^ 2 ≤ (n0 : ℝ))
    (hstackConstCutoff :
      12 * Real.log 2 ≤
        (n0 : ℝ) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3)) :
    HasRealHypercubePebblingUpperBound
      (Real.exp (4 * loss n0) *
        finiteBaseNormalizedBound (recursiveCostBound 217 n0) n0) :=
  hasRealUpperBound_of_explicitConstants_cutoff_finiteBase
    (n0 := n0)
    hn0_pos
    hn0_growth
    hsplitThreshold
    (explicit_widthFitThreshold_of_splitThreshold
      (n0 := n0) hsplitThreshold)
    hcoreNineCutoff
    hwidthConstCutoff
    hstackLogThreshold
    hstackConstCutoff

/-- For `A=4`, the `core≥9` cutoff follows from the split cutoff. -/
theorem explicit_coreNineCutoff_of_splitThreshold {n0 : ℕ}
    (hsplitThreshold : (128 * (217 : ℝ) ^ 2) ^ 2 ≤ (n0 : ℝ)) :
    81 ≤ (4 : ℝ) ^ 2 * (((3 : ℝ) * (n0 : ℝ) / 4) *
      Real.log (n0 : ℝ)) := by
  have hn12 : (12 : ℝ) ≤ (n0 : ℝ) := by
    have hbig : (12 : ℝ) ≤ (128 * (217 : ℝ) ^ 2) ^ 2 := by norm_num
    exact hbig.trans hsplitThreshold
  have hn2 : (2 : ℝ) ≤ (n0 : ℝ) := by linarith
  have hlog2Lower : (3 : ℝ) / 5 ≤ Real.log 2 := by
    have h := Real.log_two_gt_d9
    norm_num at h ⊢
    linarith
  have hlog2le : Real.log 2 ≤ Real.log (n0 : ℝ) :=
    Real.log_le_log (by norm_num : (0 : ℝ) < 2) hn2
  have hlogLower : (3 : ℝ) / 5 ≤ Real.log (n0 : ℝ) :=
    hlog2Lower.trans hlog2le
  nlinarith

/-- For `K=217`, the width constant cutoff follows from the split cutoff. -/
theorem explicit_widthConstCutoff_of_splitThreshold {n0 : ℕ}
    (hsplitThreshold : (128 * (217 : ℝ) ^ 2) ^ 2 ≤ (n0 : ℝ)) :
    Real.log 128 + 4 * Real.log 2 ≤
      ((217 : ℝ) / 30 * Real.log 2) *
        Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ)) := by
  have hn15 : (15 : ℝ) ≤ (n0 : ℝ) := by
    have hbig : (15 : ℝ) ≤ (128 * (217 : ℝ) ^ 2) ^ 2 := by norm_num
    exact hbig.trans hsplitThreshold
  have hn2 : (2 : ℝ) ≤ (n0 : ℝ) := by linarith
  have hlog2Lower : (3 : ℝ) / 5 ≤ Real.log 2 := by
    have h := Real.log_two_gt_d9
    norm_num at h ⊢
    linarith
  have hlog2le : Real.log 2 ≤ Real.log (n0 : ℝ) :=
    Real.log_le_log (by norm_num : (0 : ℝ) < 2) hn2
  have hlogLower : (3 : ℝ) / 5 ≤ Real.log (n0 : ℝ) :=
    hlog2Lower.trans hlog2le
  have hargLower : (9 : ℝ) ≤ (n0 : ℝ) * Real.log (n0 : ℝ) := by
    nlinarith
  have harg_nonneg : 0 ≤ (n0 : ℝ) * Real.log (n0 : ℝ) := by
    nlinarith
  have hsqrtLower :
      (3 : ℝ) ≤ Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ)) := by
    have hsq :
        (3 : ℝ) ^ 2 ≤
          (Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ))) ^ 2 := by
      rw [Real.sq_sqrt harg_nonneg]
      norm_num
      exact hargLower
    exact (sq_le_sq₀ (by norm_num : (0 : ℝ) ≤ 3)
      (Real.sqrt_nonneg _)).mp hsq
  have hlog2Sharp : (6931471803 : ℝ) / 10000000000 ≤ Real.log 2 := by
    have h := Real.log_two_gt_d9
    norm_num at h ⊢
    linarith
  have hcoeffLower : (5 : ℝ) ≤ (217 : ℝ) / 30 * Real.log 2 := by
    nlinarith
  have hlog2_pos : 0 < Real.log 2 :=
    Real.log_pos (by norm_num : (1 : ℝ) < 2)
  have hcoeff_nonneg : 0 ≤ (217 : ℝ) / 30 * Real.log 2 := by positivity
  have hrhsLower :
      (15 : ℝ) ≤
        ((217 : ℝ) / 30 * Real.log 2) *
          Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ)) := by
    calc
      (15 : ℝ) = 5 * 3 := by norm_num
      _ ≤ ((217 : ℝ) / 30 * Real.log 2) *
          Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ)) :=
        mul_le_mul hcoeffLower hsqrtLower
          (by norm_num : (0 : ℝ) ≤ 3) hcoeff_nonneg
  have hlog128 : Real.log 128 = 7 * Real.log 2 := by
    rw [show (128 : ℝ) = 2 ^ 7 by norm_num]
    rw [Real.log_pow]
    norm_num
  have hlhs : Real.log 128 + 4 * Real.log 2 ≤ 11 := by
    rw [hlog128]
    have hlog2le1 := log_two_le_one
    nlinarith
  calc
    Real.log 128 + 4 * Real.log 2 ≤ 11 := hlhs
    _ ≤ 15 := by norm_num
    _ ≤ ((217 : ℝ) / 30 * Real.log 2) *
          Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ)) := hrhsLower

/-- The stack logarithmic cutoff follows from the explicit split cutoff. -/
theorem explicit_stackLogThreshold_of_splitThreshold {n0 : ℕ}
    (hsplitThreshold : (128 * (217 : ℝ) ^ 2) ^ 2 ≤ (n0 : ℝ)) :
    (32 / stackMargin ^ 2) ^ 2 ≤ (n0 : ℝ) := by
  have hc_pos : 0 < stackMargin := stackMargin_pos
  have hcLower : (1 : ℝ) / 20 ≤ stackMargin := one_twentieth_le_stackMargin
  have hcSqLower : ((1 : ℝ) / 20) ^ 2 ≤ stackMargin ^ 2 :=
    (sq_le_sq₀ (by norm_num : (0 : ℝ) ≤ (1 : ℝ) / 20) hc_pos.le).mpr
      hcLower
  have hcoefLe : 32 / stackMargin ^ 2 ≤ (12800 : ℝ) := by
    rw [div_le_iff₀ (sq_pos_of_pos hc_pos)]
    nlinarith
  have hcoef_nonneg : 0 ≤ 32 / stackMargin ^ 2 := by positivity
  have hsqLe :
      (32 / stackMargin ^ 2) ^ 2 ≤ (12800 : ℝ) ^ 2 :=
    (sq_le_sq₀ hcoef_nonneg (by norm_num : (0 : ℝ) ≤ 12800)).mpr hcoefLe
  have hbig :
      (12800 : ℝ) ^ 2 ≤ (128 * (217 : ℝ) ^ 2) ^ 2 := by
    norm_num
  exact hsqLe.trans (hbig.trans hsplitThreshold)

/-- The stack constant cutoff follows from the explicit split cutoff. -/
theorem explicit_stackConstCutoff_of_splitThreshold {n0 : ℕ}
    (hsplitThreshold : (128 * (217 : ℝ) ^ 2) ^ 2 ≤ (n0 : ℝ)) :
    12 * Real.log 2 ≤
      (n0 : ℝ) * (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
  have hn240 : (240 : ℝ) ≤ (n0 : ℝ) := by
    have hbig : (240 : ℝ) ≤ (128 * (217 : ℝ) ^ 2) ^ 2 := by norm_num
    exact hbig.trans hsplitThreshold
  have hleft : 12 * Real.log 2 ≤ (12 : ℝ) := by
    have hlog2le1 := log_two_le_one
    nlinarith
  have hmiddle : (12 : ℝ) ≤ (n0 : ℝ) * ((1 : ℝ) / 20) := by
    nlinarith
  have hright :
      (n0 : ℝ) * ((1 : ℝ) / 20) ≤ (n0 : ℝ) * stackMargin :=
    mul_le_mul_of_nonneg_left one_twentieth_le_stackMargin (by positivity)
  have hmain : 12 * Real.log 2 ≤ (n0 : ℝ) * stackMargin :=
    hleft.trans (hmiddle.trans hright)
  simpa [stackMargin] using hmain

/-- Fully explicit upper-bound theorem with `A=4`, `K=217`, conditional only
on the split cutoff. -/
theorem hasRealUpperBound_of_explicitConstants_splitCutoff_finiteBase
    {n0 : ℕ}
    (hn0_pos : 0 < n0)
    (hn0_growth : 58 ≤ n0)
    (hsplitThreshold : (128 * (217 : ℝ) ^ 2) ^ 2 ≤ (n0 : ℝ)) :
    HasRealHypercubePebblingUpperBound
      (Real.exp (4 * loss n0) *
        finiteBaseNormalizedBound (recursiveCostBound 217 n0) n0) :=
  hasRealUpperBound_of_explicitConstants_mainCutoffs_finiteBase
    (n0 := n0)
    hn0_pos
    hn0_growth
    hsplitThreshold
    (explicit_coreNineCutoff_of_splitThreshold
      (n0 := n0) hsplitThreshold)
    (explicit_widthConstCutoff_of_splitThreshold
      (n0 := n0) hsplitThreshold)
    (explicit_stackLogThreshold_of_splitThreshold
      (n0 := n0) hsplitThreshold)
    (explicit_stackConstCutoff_of_splitThreshold
      (n0 := n0) hsplitThreshold)

/-- A concrete cutoff large enough for the explicit constants `A=4`,
`K=217`.  It is exactly `(128 * 217^2)^2`. -/
def explicitCutoff : ℕ :=
  36329454321664

theorem explicitCutoff_pos : 0 < explicitCutoff := by
  norm_num [explicitCutoff]

theorem explicitCutoff_growth : 58 ≤ explicitCutoff := by
  norm_num [explicitCutoff]

theorem explicitCutoff_splitThreshold :
    (128 * (217 : ℝ) ^ 2) ^ 2 ≤ (explicitCutoff : ℝ) := by
  norm_num [explicitCutoff]

/-- Fully explicit paper-parameter upper bound.  The constant is not optimized;
it is the finite-base normalized constant generated by the recursive schedule
with `A=4`, `K=217`, and `n0 = 36,329,454,321,664`. -/
theorem hasRealUpperBound_explicitConstants :
    HasRealHypercubePebblingUpperBound
      (Real.exp (4 * loss explicitCutoff) *
        finiteBaseNormalizedBound (recursiveCostBound 217 explicitCutoff)
          explicitCutoff) :=
  hasRealUpperBound_of_explicitConstants_splitCutoff_finiteBase
    (n0 := explicitCutoff)
    explicitCutoff_pos
    explicitCutoff_growth
    explicitCutoff_splitThreshold

/-- Any relationally optimal pebbling number is bounded above by the explicit
constant generated by the formal upper-bound construction. -/
theorem explicit_upper_bound_of_isOptimalNumber {n k : ℕ}
    (hopt : Pebbling.IsOptimalNumber (graph n) k) :
    (k : ℝ) ≤
      (Real.exp (4 * loss explicitCutoff) *
        finiteBaseNormalizedBound (recursiveCostBound 217 explicitCutoff)
          explicitCutoff) *
        (((4 : ℝ) / 3) ^ n) := by
  rcases hasRealUpperBound_explicitConstants n with ⟨u, hu, hu_bound⟩
  rcases hu with ⟨D, hD_size, hD_solvable⟩
  have hsolvSize : Pebbling.HasSolvableSize (graph n) (Pebbling.size D) :=
    ⟨D, rfl, hD_solvable⟩
  have hk_size : k ≤ Pebbling.size D := by
    by_contra hnot
    have hlt : Pebbling.size D < k := Nat.lt_of_not_ge hnot
    exact (hopt.2 (Pebbling.size D) hlt) hsolvSize
  have hk_u : k ≤ u := hk_size.trans hD_size
  have hk_u_real : (k : ℝ) ≤ (u : ℝ) := by exact_mod_cast hk_u
  exact hk_u_real.trans hu_bound

/-- Final packaged asymptotic bounds for any `k` certified as the optimal
pebbling number of `Q_n`: the formal lower bound and the explicit real upper
bound. -/
theorem explicit_bounds_of_isOptimalNumber {n k : ℕ}
    (hopt : Pebbling.IsOptimalNumber (graph n) k) :
    ((4 : ℚ) / 3) ^ n ≤ (k : ℚ) ∧
      (k : ℝ) ≤
        (Real.exp (4 * loss explicitCutoff) *
          finiteBaseNormalizedBound (recursiveCostBound 217 explicitCutoff)
            explicitCutoff) *
          (((4 : ℝ) / 3) ^ n) :=
  ⟨lower_bound_of_isOptimalNumber hopt,
    explicit_upper_bound_of_isOptimalNumber hopt⟩

