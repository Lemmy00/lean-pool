/-- Explicit left-tail Chernoff expression for the annulus window. -/
noncomputable def leftChernoffTerm (A K : ℝ) (lamLeft : ℕ → ℝ) (n : ℕ) : ℝ :=
  Real.exp (lamLeft n * (rIn A K n : ℝ)) *
    (((1 : ℝ) / 3) * Real.exp (-(lamLeft n)) + ((2 : ℝ) / 3)) ^
      splitA K n

/-- Explicit right-tail Chernoff expression for the annulus window. -/
noncomputable def rightChernoffTerm (A K : ℝ) (lamRight : ℕ → ℝ) (n : ℕ) : ℝ :=
  Real.exp (-(lamRight n * (rOut A K n : ℝ))) *
    (((1 : ℝ) / 3) * Real.exp (lamRight n) + ((2 : ℝ) / 3)) ^
      splitA K n

/-- Logarithmic form of the left Chernoff term. -/
theorem leftChernoffTerm_le_exp_of_log_le {A K : ℝ} {lam : ℕ → ℝ}
    {n : ℕ} {E : ℝ}
    (hlog :
      lam n * (rIn A K n : ℝ) +
          (splitA K n : ℝ) *
            Real.log (((1 : ℝ) / 3) * Real.exp (-(lam n)) +
              ((2 : ℝ) / 3)) ≤ -E) :
    leftChernoffTerm A K lam n ≤ Real.exp (-E) := by
  let b : ℝ := ((1 : ℝ) / 3) * Real.exp (-(lam n)) + ((2 : ℝ) / 3)
  have hb_pos : 0 < b := by
    dsimp [b]
    positivity
  have hpow :
      b ^ splitA K n = Real.exp ((splitA K n : ℝ) * Real.log b) := by
    calc
      b ^ splitA K n = (Real.exp (Real.log b)) ^ splitA K n := by
        rw [Real.exp_log hb_pos]
      _ = Real.exp ((splitA K n : ℝ) * Real.log b) := by
        rw [← Real.exp_nat_mul]
  calc
    leftChernoffTerm A K lam n =
        Real.exp (lam n * (rIn A K n : ℝ) +
          (splitA K n : ℝ) * Real.log b) := by
      rw [leftChernoffTerm]
      dsimp [b] at hpow ⊢
      rw [hpow, ← Real.exp_add]
    _ ≤ Real.exp (-E) := Real.exp_le_exp.mpr hlog

/-- Logarithmic form of the right Chernoff term. -/
theorem rightChernoffTerm_le_exp_of_log_le {A K : ℝ} {lam : ℕ → ℝ}
    {n : ℕ} {E : ℝ}
    (hlog :
      -(lam n * (rOut A K n : ℝ)) +
          (splitA K n : ℝ) *
            Real.log (((1 : ℝ) / 3) * Real.exp (lam n) +
              ((2 : ℝ) / 3)) ≤ -E) :
    rightChernoffTerm A K lam n ≤ Real.exp (-E) := by
  let b : ℝ := ((1 : ℝ) / 3) * Real.exp (lam n) + ((2 : ℝ) / 3)
  have hb_pos : 0 < b := by
    dsimp [b]
    positivity
  have hpow :
      b ^ splitA K n = Real.exp ((splitA K n : ℝ) * Real.log b) := by
    calc
      b ^ splitA K n = (Real.exp (Real.log b)) ^ splitA K n := by
        rw [Real.exp_log hb_pos]
      _ = Real.exp ((splitA K n : ℝ) * Real.log b) := by
        rw [← Real.exp_nat_mul]
  calc
    rightChernoffTerm A K lam n =
        Real.exp (-(lam n * (rOut A K n : ℝ)) +
          (splitA K n : ℝ) * Real.log b) := by
      rw [rightChernoffTerm]
      dsimp [b] at hpow ⊢
      rw [hpow, ← Real.exp_add]
    _ ≤ Real.exp (-E) := Real.exp_le_exp.mpr hlog

/-- A coarse second-order exponential upper bound on `[0,1]`.  The constant
`13/18` comes from the third-order Taylor bound in mathlib and is deliberately
not optimized. -/
theorem exp_le_one_add_self_add_quadratic_of_le_one {x : ℝ}
    (hx0 : 0 ≤ x) (hx1 : x ≤ 1) :
    Real.exp x ≤ 1 + x + (13 / 18) * x ^ 2 := by
  have h :=
    Real.exp_bound' (x := x) hx0 hx1 (n := 3) (by norm_num)
  have hsum :
      (∑ m ∈ Finset.range 3, x ^ m / (m.factorial : ℝ)) =
        1 + x + x ^ 2 / 2 := by
    norm_num [Finset.sum_range_succ]
  have hx3_le : x ^ 3 ≤ x ^ 2 := by
    have hmul := mul_le_mul_of_nonneg_left hx1 (sq_nonneg x)
    nlinarith
  have htail :
      x ^ 3 * ((3 : ℝ) + 1) / ((Nat.factorial 3 : ℝ) * (3 : ℝ)) ≤
        (2 / 9) * x ^ 2 := by
    norm_num
    nlinarith
  calc
    Real.exp x
        ≤ (∑ m ∈ Finset.range 3, x ^ m / (m.factorial : ℝ)) +
            x ^ 3 * ((3 : ℝ) + 1) /
              ((Nat.factorial 3 : ℝ) * (3 : ℝ)) := h
    _ ≤ 1 + x + x ^ 2 / 2 + (2 / 9) * x ^ 2 := by
          linarith
    _ = 1 + x + (13 / 18) * x ^ 2 := by ring

/-- The matching bound for `exp(-x)` on `[0,1]`. -/
theorem exp_neg_le_one_sub_self_add_quadratic_of_le_one {x : ℝ}
    (hx0 : 0 ≤ x) (hx1 : x ≤ 1) :
    Real.exp (-x) ≤ 1 - x + (13 / 18) * x ^ 2 := by
  have habs : |(-x)| ≤ 1 := by
    rw [abs_neg, abs_of_nonneg hx0]
    exact hx1
  have h :=
    Real.exp_bound (x := -x) (n := 3) habs (by norm_num)
  have hupper := (abs_sub_le_iff.mp h).1
  have hsum :
      (∑ m ∈ Finset.range 3, (-x) ^ m / (m.factorial : ℝ)) =
        1 - x + x ^ 2 / 2 := by
    norm_num [Finset.sum_range_succ]
    ring
  have hx3_le : x ^ 3 ≤ x ^ 2 := by
    have hmul := mul_le_mul_of_nonneg_left hx1 (sq_nonneg x)
    nlinarith
  have htail :
      |(-x)| ^ 3 * ((3 : ℝ) + 1) /
          ((Nat.factorial 3 : ℝ) * (3 : ℝ)) ≤
        (2 / 9) * x ^ 2 := by
    rw [abs_neg, abs_of_nonneg hx0]
    norm_num
    nlinarith
  calc
    Real.exp (-x)
        ≤ (∑ m ∈ Finset.range 3, (-x) ^ m / (m.factorial : ℝ)) +
            |(-x)| ^ 3 * ((3 : ℝ) + 1) /
              ((Nat.factorial 3 : ℝ) * (3 : ℝ)) := by
          linarith
    _ ≤ 1 - x + x ^ 2 / 2 + (2 / 9) * x ^ 2 := by
          linarith
    _ = 1 - x + (13 / 18) * x ^ 2 := by ring

/-- Left Bernoulli log-moment bound used by the annulus Chernoff estimate. -/
theorem bernoulli_third_left_log_le_quadratic {lam : ℝ}
    (hlam0 : 0 ≤ lam) (hlam1 : lam ≤ 1) :
    Real.log (((1 : ℝ) / 3) * Real.exp (-lam) + ((2 : ℝ) / 3)) ≤
      -lam / 3 + (13 / 54) * lam ^ 2 := by
  let b : ℝ := ((1 : ℝ) / 3) * Real.exp (-lam) + ((2 : ℝ) / 3)
  have hb_pos : 0 < b := by
    dsimp [b]
    positivity
  have hlog : Real.log b ≤ b - 1 :=
    Real.log_le_sub_one_of_pos hb_pos
  have hexp :=
    exp_neg_le_one_sub_self_add_quadratic_of_le_one hlam0 hlam1
  have hb :
      b - 1 ≤ -lam / 3 + (13 / 54) * lam ^ 2 := by
    have hmul :
        ((1 : ℝ) / 3) * Real.exp (-lam) ≤
          ((1 : ℝ) / 3) * (1 - lam + (13 / 18) * lam ^ 2) :=
      mul_le_mul_of_nonneg_left hexp (by norm_num : (0 : ℝ) ≤ (1 : ℝ) / 3)
    dsimp [b] at hmul ⊢
    linarith
  exact hlog.trans hb

/-- Right Bernoulli log-moment bound used by the annulus Chernoff estimate. -/
theorem bernoulli_third_right_log_le_quadratic {lam : ℝ}
    (hlam0 : 0 ≤ lam) (hlam1 : lam ≤ 1) :
    Real.log (((1 : ℝ) / 3) * Real.exp lam + ((2 : ℝ) / 3)) ≤
      lam / 3 + (13 / 54) * lam ^ 2 := by
  let b : ℝ := ((1 : ℝ) / 3) * Real.exp lam + ((2 : ℝ) / 3)
  have hb_pos : 0 < b := by
    dsimp [b]
    positivity
  have hlog : Real.log b ≤ b - 1 :=
    Real.log_le_sub_one_of_pos hb_pos
  have hexp :=
    exp_le_one_add_self_add_quadratic_of_le_one hlam0 hlam1
  have hb :
      b - 1 ≤ lam / 3 + (13 / 54) * lam ^ 2 := by
    have hmul :
        ((1 : ℝ) / 3) * Real.exp lam ≤
          ((1 : ℝ) / 3) * (1 + lam + (13 / 18) * lam ^ 2) :=
      mul_le_mul_of_nonneg_left hexp (by norm_num : (0 : ℝ) ≤ (1 : ℝ) / 3)
    dsimp [b] at hmul ⊢
    linarith
  exact hlog.trans hb

/-- A canonical nonnegative Chernoff parameter of order `width/a`.  The
constant is deliberately exposed in the definition; future analytic estimates
may replace this wrapper if a sharper constant is more convenient. -/
noncomputable def annulusChernoffLambda (A K : ℝ) (n : ℕ) : ℝ :=
  3 * (annulusWidth A K n : ℝ) / ((splitA K n : ℝ) + 1)

theorem annulusChernoffLambda_nonneg (A K : ℝ) (n : ℕ) :
    0 ≤ annulusChernoffLambda A K n := by
  unfold annulusChernoffLambda
  positivity

/-- If `3w≤a`, then the standard Chernoff parameter
`λ=3w/(a+1)` is at most one. -/
theorem annulusChernoffLambda_le_one_of_three_width_le_splitA
    {A K : ℝ} {n : ℕ}
    (hwidth : 3 * annulusWidth A K n ≤ splitA K n) :
    annulusChernoffLambda A K n ≤ 1 := by
  unfold annulusChernoffLambda
  have hreal :
      (3 : ℝ) * (annulusWidth A K n : ℝ) ≤ (splitA K n : ℝ) := by
    exact_mod_cast hwidth
  have hden_pos : 0 < (splitA K n : ℝ) + 1 := by positivity
  rw [div_le_iff₀ hden_pos]
  linarith

/-- Left-tail standard-lambda log estimate for the annulus window. -/
theorem left_standard_chernoff_log_le_of_width_exponent
    {A K : ℝ} {n : ℕ} {E : ℝ}
    (hcenter : annulusWidth A K n ≤ splitA K n / 3)
    (hlam_le_one : annulusChernoffLambda A K n ≤ 1)
    (hE :
      E ≤ (5 / 6) *
        ((annulusWidth A K n : ℝ) ^ 2 / ((splitA K n : ℝ) + 1))) :
    annulusChernoffLambda A K n * (rIn A K n : ℝ) +
        (splitA K n : ℝ) *
          Real.log (((1 : ℝ) / 3) *
              Real.exp (-(annulusChernoffLambda A K n)) +
            ((2 : ℝ) / 3)) ≤ -E := by
  let lam : ℝ := annulusChernoffLambda A K n
  let a : ℝ := splitA K n
  let w : ℝ := annulusWidth A K n
  have hlam0 : 0 ≤ lam := by
    simpa [lam] using annulusChernoffLambda_nonneg A K n
  have ha_nonneg : 0 ≤ a := by positivity
  have hden_pos : 0 < a + 1 := by positivity
  have hrIn : (rIn A K n : ℝ) ≤ a / 3 - w := by
    simpa [a, w] using rIn_real_le_third_sub_width
      (A := A) (K := K) (n := n) hcenter
  have hlog :=
    bernoulli_third_left_log_le_quadratic
      (lam := lam) hlam0 (by simpa [lam] using hlam_le_one)
  have hfirst :
      lam * (rIn A K n : ℝ) ≤ lam * (a / 3 - w) :=
    mul_le_mul_of_nonneg_left hrIn hlam0
  have hsecond :
      a *
          Real.log (((1 : ℝ) / 3) *
              Real.exp (-(annulusChernoffLambda A K n)) +
            ((2 : ℝ) / 3)) ≤
        a * (-lam / 3 + (13 / 54) * lam ^ 2) := by
    have hlog' :
        Real.log (((1 : ℝ) / 3) *
              Real.exp (-(annulusChernoffLambda A K n)) +
            ((2 : ℝ) / 3)) ≤
          -lam / 3 + (13 / 54) * lam ^ 2 := by
      simpa [lam] using hlog
    exact mul_le_mul_of_nonneg_left hlog' ha_nonneg
  have hquad :
      lam * (a / 3 - w) +
          a * (-lam / 3 + (13 / 54) * lam ^ 2) ≤
        -((5 / 6) * (w ^ 2 / (a + 1))) := by
    dsimp [lam, a, w, annulusChernoffLambda]
    field_simp [hden_pos.ne']
    ring_nf
    nlinarith [sq_nonneg w, mul_nonneg ha_nonneg (sq_nonneg w)]
  have htail : -((5 / 6) * (w ^ 2 / (a + 1))) ≤ -E := by
    simpa [a, w] using neg_le_neg hE
  calc
    annulusChernoffLambda A K n * (rIn A K n : ℝ) +
        (splitA K n : ℝ) *
          Real.log (((1 : ℝ) / 3) *
              Real.exp (-(annulusChernoffLambda A K n)) +
            ((2 : ℝ) / 3))
        ≤ lam * (a / 3 - w) +
            a * (-lam / 3 + (13 / 54) * lam ^ 2) := by
          dsimp [lam, a]
          linarith
    _ ≤ -((5 / 6) * (w ^ 2 / (a + 1))) := hquad
    _ ≤ -E := htail

/-- Right-tail standard-lambda log estimate for the annulus window.  The
assumption `9≤w` absorbs the one-unit floor slack in `rOut`. -/
theorem right_standard_chernoff_log_le_of_width_exponent
    {A K : ℝ} {n : ℕ} {E : ℝ}
    (hwidth : 9 ≤ (annulusWidth A K n : ℝ))
    (hlam_le_one : annulusChernoffLambda A K n ≤ 1)
    (hE :
      E ≤ (1 / 2) *
        ((annulusWidth A K n : ℝ) ^ 2 / ((splitA K n : ℝ) + 1))) :
    -(annulusChernoffLambda A K n * (rOut A K n : ℝ)) +
        (splitA K n : ℝ) *
          Real.log (((1 : ℝ) / 3) *
              Real.exp (annulusChernoffLambda A K n) +
            ((2 : ℝ) / 3)) ≤ -E := by
  let lam : ℝ := annulusChernoffLambda A K n
  let a : ℝ := splitA K n
  let w : ℝ := annulusWidth A K n
  have hlam0 : 0 ≤ lam := by
    simpa [lam] using annulusChernoffLambda_nonneg A K n
  have ha_nonneg : 0 ≤ a := by positivity
  have hw_nonneg : 0 ≤ w := by positivity
  have hden_pos : 0 < a + 1 := by positivity
  have hrOut : a / 3 + w - 1 ≤ (rOut A K n : ℝ) := by
    simpa [a, w] using third_add_width_sub_one_le_rOut_real
      (A := A) (K := K) (n := n)
  have hlog :=
    bernoulli_third_right_log_le_quadratic
      (lam := lam) hlam0 (by simpa [lam] using hlam_le_one)
  have hfirst :
      -(lam * (rOut A K n : ℝ)) ≤ -(lam * (a / 3 + w - 1)) := by
    have hmul := mul_le_mul_of_nonneg_left hrOut hlam0
    exact neg_le_neg hmul
  have hsecond :
      a *
          Real.log (((1 : ℝ) / 3) *
              Real.exp (annulusChernoffLambda A K n) +
            ((2 : ℝ) / 3)) ≤
        a * (lam / 3 + (13 / 54) * lam ^ 2) := by
    have hlog' :
        Real.log (((1 : ℝ) / 3) *
              Real.exp (annulusChernoffLambda A K n) +
            ((2 : ℝ) / 3)) ≤
          lam / 3 + (13 / 54) * lam ^ 2 := by
      simpa [lam] using hlog
    exact mul_le_mul_of_nonneg_left hlog' ha_nonneg
  have hwidth_w : 9 ≤ w := by
    simpa [w] using hwidth
  have hw_sq : 9 * w ≤ w ^ 2 := by
    have hmul := mul_le_mul_of_nonneg_right hwidth_w hw_nonneg
    nlinarith
  have h_a_part : 18 * a * w ≤ 2 * a * w ^ 2 := by
    have hmul :=
      mul_le_mul_of_nonneg_left hw_sq (by positivity : 0 ≤ 2 * a)
    nlinarith
  have h_const_part : 18 * w ≤ 15 * w ^ 2 := by
    nlinarith
  have hquad :
      -(lam * (a / 3 + w - 1)) +
          a * (lam / 3 + (13 / 54) * lam ^ 2) ≤
        -((1 / 2) * (w ^ 2 / (a + 1))) := by
    dsimp [lam, a, w, annulusChernoffLambda]
    field_simp [hden_pos.ne']
    ring_nf
    nlinarith [h_a_part, h_const_part]
  have htail : -((1 / 2) * (w ^ 2 / (a + 1))) ≤ -E := by
    simpa [a, w] using neg_le_neg hE
  calc
    -(annulusChernoffLambda A K n * (rOut A K n : ℝ)) +
        (splitA K n : ℝ) *
          Real.log (((1 : ℝ) / 3) *
              Real.exp (annulusChernoffLambda A K n) +
            ((2 : ℝ) / 3))
        ≤ -(lam * (a / 3 + w - 1)) +
            a * (lam / 3 + (13 / 54) * lam ^ 2) := by
          dsimp [lam, a]
          linarith
    _ ≤ -((1 / 2) * (w ^ 2 / (a + 1))) := hquad
    _ ≤ -E := htail

/-- Algebraic form of the Chernoff exponent target with `E_n=6 log n`. -/
theorem chernoff_six_log_of_width_sq {A K : ℝ} {n : ℕ}
    (hwidthSq :
      12 * ((splitA K n : ℝ) + 1) * Real.log (n : ℝ) ≤
        (annulusWidth A K n : ℝ) ^ 2) :
    6 * Real.log (n : ℝ) ≤
      (1 / 2) *
        ((annulusWidth A K n : ℝ) ^ 2 /
          ((splitA K n : ℝ) + 1)) := by
  have hden_pos : 0 < (splitA K n : ℝ) + 1 := by positivity
  rw [show (1 / 2) *
        ((annulusWidth A K n : ℝ) ^ 2 / ((splitA K n : ℝ) + 1)) =
      (annulusWidth A K n : ℝ) ^ 2 /
        (2 * ((splitA K n : ℝ) + 1)) by
        field_simp [hden_pos.ne']]
  rw [le_div_iff₀ (by positivity : 0 < 2 * ((splitA K n : ℝ) + 1))]
  nlinarith

/-- Multiplication-form version of the current reduced wrapper.  The remaining
real estimates are now stated without division:

* `16 * leftChernoffTerm ≤ loss`;
* `16 * rightChernoffTerm ≤ loss`;
* the multiplication-form Bernstein width threshold;
* the multiplication-form stack threshold;
* `(4/3)^a ≥ n^2` for ceiling slack.
-/
theorem hasRealUpperBound_of_recursiveCostBound_allMulThresholds_finiteBase
    {K A : ℝ} {n0 : ℕ} {lamLeft lamRight : ℕ → ℝ}
    (hn0_pos : 0 < n0)
    (hquarter :
      ∀ n : ℕ, n0 ≤ n → 4 * splitM K n ≤ n)
    (hlamLeft :
      ∀ n : ℕ, n0 ≤ n → 0 ≤ lamLeft n)
    (hlamRight :
      ∀ n : ℕ, n0 ≤ n → 0 ≤ lamRight n)
    (hleftMul :
      ∀ n : ℕ, n0 ≤ n →
        16 * leftChernoffTerm A K lamLeft n ≤ loss n)
    (hrightMul :
      ∀ n : ℕ, n0 ≤ n →
        16 * rightChernoffTerm A K lamRight n ≤ loss n)
    (hlogWidthMul :
      ∀ n : ℕ, n0 ≤ n →
        128 * (2 ^ (2 * annulusWidth A K n) : ℝ) *
            (((splitA K n + 1 : ℕ) : ℝ) * Real.log 2) ≤
          (loss n) ^ 2 * (minPile (splitM K n) : ℝ))
    (hstackMul :
      ∀ n : ℕ, n0 ≤ n →
        2 * ((n : ℝ) ^ 2) * (2 ^ rOut A K n : ℝ) ≤
          (minPile (splitM K n) : ℝ) *
            (((4 : ℝ) / 3) ^ splitA K n))
    (hceilSq :
      ∀ n : ℕ, n0 ≤ n →
        (n : ℝ) ^ 2 ≤ (((4 : ℝ) / 3) ^ splitA K n)) :
    HasRealHypercubePebblingUpperBound
      (Real.exp (4 * loss n0) *
        finiteBaseNormalizedBound (recursiveCostBound K n0) n0) :=
  hasRealUpperBound_of_recursiveCostBound_tailBudgets_mulThresholds_finiteBase
    (K := K) (A := A) (n0 := n0)
    hn0_pos hquarter hlamLeft hlamRight
    (fun n hn => by
      have h : 16 *
          (Real.exp (lamLeft n * (rIn A K n : ℝ)) *
            (((1 : ℝ) / 3) * Real.exp (-(lamLeft n)) + ((2 : ℝ) / 3)) ^
              splitA K n) ≤
          loss n := by
        simpa [leftChernoffTerm] using hleftMul n hn
      linarith)
    (fun n hn => by
      have h : 16 *
          (Real.exp (-(lamRight n * (rOut A K n : ℝ))) *
            (((1 : ℝ) / 3) * Real.exp (lamRight n) + ((2 : ℝ) / 3)) ^
              splitA K n) ≤
          loss n := by
        simpa [rightChernoffTerm] using hrightMul n hn
      linarith)
    hlogWidthMul
    hstackMul
    hceilSq

/-- Same strongest wrapper, but with the split estimate supplied in real form
`splitM n ≤ n/4` and the ceiling slack supplied in the coarser form
`n^2 ≤ (4/3)^(n/2)`. -/
theorem hasRealUpperBound_of_recursiveCostBound_realSplit_allMulThresholds_finiteBase
    {K A : ℝ} {n0 : ℕ} {lamLeft lamRight : ℕ → ℝ}
    (hn0_pos : 0 < n0)
    (hsplitReal :
      ∀ n : ℕ, n0 ≤ n → (splitM K n : ℝ) ≤ (n : ℝ) / 4)
    (hlamLeft :
      ∀ n : ℕ, n0 ≤ n → 0 ≤ lamLeft n)
    (hlamRight :
      ∀ n : ℕ, n0 ≤ n → 0 ≤ lamRight n)
    (hleftMul :
      ∀ n : ℕ, n0 ≤ n →
        16 * leftChernoffTerm A K lamLeft n ≤ loss n)
    (hrightMul :
      ∀ n : ℕ, n0 ≤ n →
        16 * rightChernoffTerm A K lamRight n ≤ loss n)
    (hlogWidthMul :
      ∀ n : ℕ, n0 ≤ n →
        128 * (2 ^ (2 * annulusWidth A K n) : ℝ) *
            (((splitA K n + 1 : ℕ) : ℝ) * Real.log 2) ≤
          (loss n) ^ 2 * (minPile (splitM K n) : ℝ))
    (hstackMul :
      ∀ n : ℕ, n0 ≤ n →
        2 * ((n : ℝ) ^ 2) * (2 ^ rOut A K n : ℝ) ≤
          (minPile (splitM K n) : ℝ) *
            (((4 : ℝ) / 3) ^ splitA K n))
    (hceilHalf :
      ∀ n : ℕ, n0 ≤ n →
        (n : ℝ) ^ 2 ≤ (((4 : ℝ) / 3) ^ (n / 2))) :
    HasRealHypercubePebblingUpperBound
      (Real.exp (4 * loss n0) *
        finiteBaseNormalizedBound (recursiveCostBound K n0) n0) :=
  hasRealUpperBound_of_recursiveCostBound_allMulThresholds_finiteBase
    (K := K) (A := A) (n0 := n0)
    hn0_pos
    (fun n hn => four_mul_splitM_le_of_real_le_quarter (hsplitReal n hn))
    hlamLeft
    hlamRight
    hleftMul
    hrightMul
    hlogWidthMul
    hstackMul
    (fun n hn =>
      ceilingSq_of_pow_half
        (n_div_two_le_splitA_of_four_mul_le
          (four_mul_splitM_le_of_real_le_quarter (hsplitReal n hn)))
        (hceilHalf n hn))

