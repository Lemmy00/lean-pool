/-- The positive linear margin available in the stack estimate:
`log(4/3) - (log 2)/3 = (1/3)log(32/27) > 0`. -/
theorem stack_linear_margin_nonneg :
    0 ≤ Real.log ((4 : ℝ) / 3) - Real.log 2 / 3 := by
  have hlogpos : 0 < Real.log ((32 : ℝ) / 27) :=
    Real.log_pos (by norm_num : (1 : ℝ) < (32 : ℝ) / 27)
  have htriple :
      3 * (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) =
        Real.log ((32 : ℝ) / 27) := by
    rw [show (32 : ℝ) / 27 = ((4 : ℝ) / 3) ^ 3 / 2 by norm_num]
    rw [Real.log_div
      (by norm_num : (((4 : ℝ) / 3) ^ 3) ≠ 0)
      (by norm_num : (2 : ℝ) ≠ 0)]
    rw [Real.log_pow]
    ring_nf
  nlinarith

/-- The positive linear margin in the stack estimate. -/
noncomputable def stackMargin : ℝ :=
  Real.log ((4 : ℝ) / 3) - Real.log 2 / 3

/-- Strict positivity of the stack margin:
`log(4/3)-log(2)/3 = (1/3)log(32/27)`. -/
theorem stackMargin_pos : 0 < stackMargin := by
  have hlogpos : 0 < Real.log ((32 : ℝ) / 27) :=
    Real.log_pos (by norm_num : (1 : ℝ) < (32 : ℝ) / 27)
  have htriple : 3 * stackMargin = Real.log ((32 : ℝ) / 27) := by
    rw [stackMargin]
    rw [show (32 : ℝ) / 27 = ((4 : ℝ) / 3) ^ 3 / 2 by norm_num]
    rw [Real.log_div
      (by norm_num : (((4 : ℝ) / 3) ^ 3) ≠ 0)
      (by norm_num : (2 : ℝ) ≠ 0)]
    rw [Real.log_pow]
    ring_nf
  nlinarith

/-- A convenient certified lower bound for the stack margin. -/
theorem one_twentieth_le_stackMargin : (1 : ℝ) / 20 ≤ stackMargin := by
  have hlogLower : (5 : ℝ) / 32 ≤ Real.log ((32 : ℝ) / 27) := by
    have h :=
      Real.one_sub_inv_le_log_of_pos
        (by norm_num : (0 : ℝ) < (32 : ℝ) / 27)
    norm_num at h ⊢
    exact h
  have htriple : 3 * stackMargin = Real.log ((32 : ℝ) / 27) := by
    rw [stackMargin]
    rw [show (32 : ℝ) / 27 = ((4 : ℝ) / 3) ^ 3 / 2 by norm_num]
    rw [Real.log_div
      (by norm_num : (((4 : ℝ) / 3) ^ 3) ≠ 0)
      (by norm_num : (2 : ℝ) ≠ 0)]
    rw [Real.log_pow]
    ring_nf
  nlinarith

/-- Corrected coarse sufficient condition for the stack core log budget.  It
keeps the paired linear margin
`a*(log(4/3)-log 2/3)` before using `a≥3n/4`. -/
theorem stack_core_log_budget_of_linear_margin {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A) (hn : 2 ≤ n)
    (ha_lower : (3 : ℝ) * (n : ℝ) / 4 ≤ (splitA K n : ℝ))
    (hcoarse :
      Real.log 2 + 2 * Real.log (n : ℝ) +
          (A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1) *
            Real.log 2 ≤
        (K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) / 5 - 1) *
            Real.log 2 +
          ((3 : ℝ) * (n : ℝ) / 4) *
            (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3)) :
    Real.log 2 + 2 * Real.log (n : ℝ) +
        (((splitA K n / 3 : ℕ) : ℝ) + annulusWidthCore A K n + 1) *
          Real.log 2 ≤
      ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2 +
        (splitA K n : ℝ) * Real.log ((4 : ℝ) / 3) := by
  have hlog2_nonneg : 0 ≤ Real.log 2 :=
    (Real.log_pos (by norm_num : (1 : ℝ) < 2)).le
  have hmargin_nonneg := stack_linear_margin_nonneg
  have hdiva :
      ((splitA K n / 3 : ℕ) : ℝ) ≤ (splitA K n : ℝ) / 3 :=
    nat_div_real_le_div (splitA K n) 3 (by decide)
  have hwidth :=
    annulusWidthCore_le_sqrt_three_n_log
      (A := A) (K := K) (n := n) hA hn
  have hlhsTerm :
      (((splitA K n / 3 : ℕ) : ℝ) + annulusWidthCore A K n + 1) *
          Real.log 2 ≤
        ((splitA K n : ℝ) / 3 +
            A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1) *
          Real.log 2 := by
    have hinside :
        ((splitA K n / 3 : ℕ) : ℝ) + annulusWidthCore A K n + 1 ≤
          (splitA K n : ℝ) / 3 +
            A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1 := by
      linarith
    exact mul_le_mul_of_nonneg_right hinside hlog2_nonneg
  have hcore := splitM_div_five_real_lower_bound (K := K) (n := n)
  have hmargin :
      ((3 : ℝ) * (n : ℝ) / 4) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) ≤
        (splitA K n : ℝ) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) :=
    mul_le_mul_of_nonneg_right ha_lower hmargin_nonneg
  have hrhs :
      (K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) / 5 - 1) *
            Real.log 2 +
          ((3 : ℝ) * (n : ℝ) / 4) *
            (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) ≤
        ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2 +
          (splitA K n : ℝ) * Real.log ((4 : ℝ) / 3) -
          (splitA K n : ℝ) / 3 * Real.log 2 := by
    have hcore_log2 := mul_le_mul_of_nonneg_right hcore hlog2_nonneg
    nlinarith
  calc
    Real.log 2 + 2 * Real.log (n : ℝ) +
        (((splitA K n / 3 : ℕ) : ℝ) + annulusWidthCore A K n + 1) *
          Real.log 2
        ≤ Real.log 2 + 2 * Real.log (n : ℝ) +
          ((splitA K n : ℝ) / 3 +
              A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1) *
            Real.log 2 := by
          linarith
    _ = (Real.log 2 + 2 * Real.log (n : ℝ) +
          (A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1) *
            Real.log 2) +
          (splitA K n : ℝ) / 3 * Real.log 2 := by ring
    _ ≤ ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2 +
          (splitA K n : ℝ) * Real.log ((4 : ℝ) / 3) := by
      nlinarith [hcoarse, hrhs]

theorem sqrt_three_n_log_eq (n : ℕ) :
    Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) =
      Real.sqrt 3 * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) := by
  rw [show 3 * (n : ℝ) * Real.log (n : ℝ) =
      3 * ((n : ℝ) * Real.log (n : ℝ)) by ring]
  rw [Real.sqrt_mul (by norm_num : (0 : ℝ) ≤ 3)]

/-- Coefficient form of the width coarse estimate.  The only growing term on
the right is now `sqrt(n log n)` with coefficient
`(K/5-2A sqrt 3) log 2`. -/
theorem width_coarse_of_sqrt_margin {A K : ℝ} {n : ℕ}
    (hmargin :
      Real.log 128 + 3 * Real.log 2 +
          Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) +
          4 * Real.log (n : ℝ) ≤
        ((K / 5 - 2 * A * Real.sqrt 3) * Real.log 2) *
          Real.sqrt ((n : ℝ) * Real.log (n : ℝ))) :
    Real.log 128 + (2 *
        (A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1)) *
        Real.log 2 +
        Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) ≤
      -4 * Real.log (n : ℝ) +
        (K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) / 5 - 1) *
          Real.log 2 := by
  rw [sqrt_three_n_log_eq n]
  ring_nf at hmargin ⊢
  linarith

/-- Coefficient form of the corrected stack-margin estimate. -/
theorem stack_margin_of_sqrt_margin {A K : ℝ} {n : ℕ}
    (hmargin :
      2 * Real.log (n : ℝ) + 3 * Real.log 2 ≤
        ((K / 5 - A * Real.sqrt 3) * Real.log 2) *
            Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) +
          ((3 : ℝ) * (n : ℝ) / 4) *
            (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3)) :
    Real.log 2 + 2 * Real.log (n : ℝ) +
        (A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1) *
          Real.log 2 ≤
      (K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) / 5 - 1) *
          Real.log 2 +
        ((3 : ℝ) * (n : ℝ) / 4) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
  rw [sqrt_three_n_log_eq n]
  ring_nf at hmargin ⊢
  linarith

/-- A simple constant-domination sufficient condition for the width sqrt
margin.  The stronger but convenient assumption `15A√3≤K` leaves a positive
coefficient `K/15` for the residual logarithmic terms. -/
theorem width_sqrt_margin_of_K_ge {A K : ℝ} {n : ℕ}
    (hKdom : 15 * A * Real.sqrt 3 ≤ K)
    (hbudget :
      Real.log 128 + 3 * Real.log 2 +
          Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) +
          4 * Real.log (n : ℝ) ≤
        (K / 15 * Real.log 2) *
          Real.sqrt ((n : ℝ) * Real.log (n : ℝ))) :
    Real.log 128 + 3 * Real.log 2 +
        Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) +
        4 * Real.log (n : ℝ) ≤
      ((K / 5 - 2 * A * Real.sqrt 3) * Real.log 2) *
        Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) := by
  have hlog2_nonneg : 0 ≤ Real.log 2 :=
    (Real.log_pos (by norm_num : (1 : ℝ) < 2)).le
  have hsqrt_nonneg :
      0 ≤ Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
    Real.sqrt_nonneg _
  have hcoeff : K / 15 ≤ K / 5 - 2 * A * Real.sqrt 3 := by
    nlinarith
  have hmul := mul_le_mul_of_nonneg_right hcoeff hlog2_nonneg
  have hmul2 := mul_le_mul_of_nonneg_right hmul hsqrt_nonneg
  exact hbudget.trans hmul2

/-- Once `K≥5A√3`, the stack sqrt coefficient is nonnegative, so the linear
margin alone can pay for the remaining logarithmic terms. -/
theorem stack_sqrt_margin_of_linear_budget {A K : ℝ} {n : ℕ}
    (hKdom : 5 * A * Real.sqrt 3 ≤ K)
    (hbudget :
      2 * Real.log (n : ℝ) + 3 * Real.log 2 ≤
        ((3 : ℝ) * (n : ℝ) / 4) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3)) :
    2 * Real.log (n : ℝ) + 3 * Real.log 2 ≤
      ((K / 5 - A * Real.sqrt 3) * Real.log 2) *
          Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) +
        ((3 : ℝ) * (n : ℝ) / 4) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
  have hlog2_nonneg : 0 ≤ Real.log 2 :=
    (Real.log_pos (by norm_num : (1 : ℝ) < 2)).le
  have hsqrt_nonneg :
      0 ≤ Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
    Real.sqrt_nonneg _
  have hcoeff : 0 ≤ K / 5 - A * Real.sqrt 3 := by nlinarith
  have hterm :
      0 ≤ ((K / 5 - A * Real.sqrt 3) * Real.log 2) *
        Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) := by
    positivity
  linarith

/-- A small numerical bound used to simplify logarithmic width budgets. -/
theorem log_two_le_one : Real.log 2 ≤ 1 := by
  have h := Real.log_le_sub_one_of_pos (by norm_num : (0 : ℝ) < 2)
  norm_num at h
  exact h

/-- Since `log 2≤1`, the factor `log 2` inside
`log((n+1)log 2)` can be discarded. -/
theorem log_succ_mul_log_two_le_log_succ {n : ℕ} :
    Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) ≤
      Real.log (((n + 1 : ℕ) : ℝ)) := by
  have hlog2_pos : 0 < Real.log 2 :=
    Real.log_pos (by norm_num : (1 : ℝ) < 2)
  have harg_pos : 0 < (((n + 1 : ℕ) : ℝ) * Real.log 2) := by
    positivity
  have hn_nonneg : 0 ≤ ((n + 1 : ℕ) : ℝ) := by positivity
  have hle :
      ((n + 1 : ℕ) : ℝ) * Real.log 2 ≤ ((n + 1 : ℕ) : ℝ) := by
    calc
      ((n + 1 : ℕ) : ℝ) * Real.log 2
          ≤ ((n + 1 : ℕ) : ℝ) * 1 :=
            mul_le_mul_of_nonneg_left log_two_le_one hn_nonneg
      _ = ((n + 1 : ℕ) : ℝ) := by ring
  exact Real.log_le_log harg_pos hle

/-- For `n≥1`, `n+1≤2n`, hence `log(n+1)≤log 2+log n`. -/
theorem log_succ_le_log_two_add_log {n : ℕ} (hn : 1 ≤ n) :
    Real.log (((n + 1 : ℕ) : ℝ)) ≤
      Real.log 2 + Real.log (n : ℝ) := by
  have hn_pos_nat : 0 < n := by omega
  have hn_pos : 0 < (n : ℝ) := by exact_mod_cast hn_pos_nat
  have hle_nat : n + 1 ≤ 2 * n := by omega
  have hle : ((n + 1 : ℕ) : ℝ) ≤ (2 : ℝ) * (n : ℝ) := by
    exact_mod_cast hle_nat
  calc
    Real.log (((n + 1 : ℕ) : ℝ))
        ≤ Real.log ((2 : ℝ) * (n : ℝ)) := by
          exact Real.log_le_log (by positivity) hle
    _ = Real.log 2 + Real.log (n : ℝ) := by
          rw [Real.log_mul (by norm_num : (2 : ℝ) ≠ 0) hn_pos.ne']

/-- A cleaner sufficient form of the residual width budget. -/
theorem width_log_budget_of_simplified_log_budget {K : ℝ} {n : ℕ}
    (hn : 1 ≤ n)
    (hbudget :
      Real.log 128 + 4 * Real.log 2 + 5 * Real.log (n : ℝ) ≤
        (K / 15 * Real.log 2) *
          Real.sqrt ((n : ℝ) * Real.log (n : ℝ))) :
    Real.log 128 + 3 * Real.log 2 +
        Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) +
        4 * Real.log (n : ℝ) ≤
      (K / 15 * Real.log 2) *
        Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) := by
  have hmiddle :
      Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) ≤
        Real.log 2 + Real.log (n : ℝ) :=
    log_succ_mul_log_two_le_log_succ.trans
      (log_succ_le_log_two_add_log (n := n) hn)
  have hcoarse :
      Real.log 128 + 3 * Real.log 2 +
          Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) +
          4 * Real.log (n : ℝ) ≤
        Real.log 128 + 4 * Real.log 2 + 5 * Real.log (n : ℝ) := by
    linarith
  exact hcoarse.trans hbudget

/-- Split form of the residual stack budget: one inequality pays for
`2 log n`, and the other pays for the constant `3 log 2`. -/
theorem stack_linear_budget_of_split_bounds {n : ℕ}
    (hlog :
      2 * Real.log (n : ℝ) ≤
        ((n : ℝ) / 2) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3))
    (hconst :
      3 * Real.log 2 ≤
        ((n : ℝ) / 4) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3)) :
    2 * Real.log (n : ℝ) + 3 * Real.log 2 ≤
      ((3 : ℝ) * (n : ℝ) / 4) *
        (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
  nlinarith

/-- The elementary comparison `log n≤sqrt(n log n)` for `n≥1`. -/
theorem log_le_sqrt_n_log {n : ℕ} (hn : 1 ≤ n) :
    Real.log (n : ℝ) ≤
      Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) := by
  have hlog_nonneg : 0 ≤ Real.log (n : ℝ) :=
    Real.log_natCast_nonneg n
  have hn_nonneg : 0 ≤ (n : ℝ) := by positivity
  have hlog_le_n : Real.log (n : ℝ) ≤ (n : ℝ) :=
    Real.log_le_self hn_nonneg
  have hsq :
      (Real.log (n : ℝ)) ^ 2 ≤
        (n : ℝ) * Real.log (n : ℝ) := by
    calc
      (Real.log (n : ℝ)) ^ 2
          = Real.log (n : ℝ) * Real.log (n : ℝ) := by ring
      _ ≤ (n : ℝ) * Real.log (n : ℝ) :=
          mul_le_mul_of_nonneg_right hlog_le_n hlog_nonneg
  have hsqrt := Real.sqrt_le_sqrt hsq
  rwa [Real.sqrt_sq_eq_abs, abs_of_nonneg hlog_nonneg] at hsqrt

/-- Explicit large-`n` sufficient condition for the split estimate
`K^2 log n≤n/64`.  It is intentionally coarse, but isolates this residual
analytic input behind a single quadratic threshold. -/
theorem split_log_budget_of_quadratic_threshold {K : ℝ} {n : ℕ}
    (hthreshold : (128 * K ^ 2) ^ 2 ≤ (n : ℝ)) :
    K ^ 2 * Real.log (n : ℝ) ≤ (n : ℝ) / 64 := by
  have hK2_nonneg : 0 ≤ K ^ 2 := sq_nonneg K
  have hcoef_nonneg : 0 ≤ 128 * K ^ 2 := by positivity
  have hn_nonneg : 0 ≤ (n : ℝ) := by positivity
  have hsqrt_threshold : 128 * K ^ 2 ≤ Real.sqrt (n : ℝ) := by
    have hsqrt := Real.sqrt_le_sqrt hthreshold
    have hleft :
        Real.sqrt ((128 * K ^ 2) ^ 2) = 128 * K ^ 2 := by
      rw [Real.sqrt_sq_eq_abs, abs_of_nonneg hcoef_nonneg]
    rwa [hleft] at hsqrt
  have hlog_half :=
    Real.log_natCast_le_rpow_div n (by norm_num : (0 : ℝ) < 1 / 2)
  have hlog_sqrt : Real.log (n : ℝ) ≤ 2 * Real.sqrt (n : ℝ) := by
    rw [← Real.sqrt_eq_rpow] at hlog_half
    calc
      Real.log (n : ℝ) ≤ Real.sqrt (n : ℝ) / (1 / 2) := hlog_half
      _ = 2 * Real.sqrt (n : ℝ) := by ring
  have hlog_mul :
      K ^ 2 * Real.log (n : ℝ) ≤
        K ^ 2 * (2 * Real.sqrt (n : ℝ)) :=
    mul_le_mul_of_nonneg_left hlog_sqrt hK2_nonneg
  have hsqrt_mul :
      (128 * K ^ 2) * Real.sqrt (n : ℝ) ≤ (n : ℝ) := by
    have hmul :=
      mul_le_mul_of_nonneg_right hsqrt_threshold (Real.sqrt_nonneg (n : ℝ))
    simpa [Real.mul_self_sqrt hn_nonneg, mul_assoc] using hmul
  have hmain :
      K ^ 2 * (2 * Real.sqrt (n : ℝ)) ≤ (n : ℝ) / 64 := by
    nlinarith
  exact hlog_mul.trans hmain

/-- Explicit threshold for the stack log-linear budget. -/
theorem stack_log_linear_budget_of_quadratic_threshold {n : ℕ}
    (hthreshold : (32 / stackMargin ^ 2) ^ 2 ≤ (n : ℝ)) :
    16 * Real.log (n : ℝ) ≤
      (n : ℝ) *
        (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) ^ 2 := by
  have hc_pos : 0 < stackMargin := stackMargin_pos
  have hc_sq_pos : 0 < stackMargin ^ 2 := sq_pos_of_pos hc_pos
  have hcoef_nonneg : 0 ≤ 32 / stackMargin ^ 2 := by positivity
  have hn_nonneg : 0 ≤ (n : ℝ) := by positivity
  have hsqrt_threshold : 32 / stackMargin ^ 2 ≤ Real.sqrt (n : ℝ) := by
    have hsqrt := Real.sqrt_le_sqrt hthreshold
    have hleft :
        Real.sqrt ((32 / stackMargin ^ 2) ^ 2) =
          32 / stackMargin ^ 2 := by
      rw [Real.sqrt_sq_eq_abs, abs_of_nonneg hcoef_nonneg]
    rwa [hleft] at hsqrt
  have hlog_half :=
    Real.log_natCast_le_rpow_div n (by norm_num : (0 : ℝ) < 1 / 2)
  have hlog_sqrt : Real.log (n : ℝ) ≤ 2 * Real.sqrt (n : ℝ) := by
    rw [← Real.sqrt_eq_rpow] at hlog_half
    calc
      Real.log (n : ℝ) ≤ Real.sqrt (n : ℝ) / (1 / 2) := hlog_half
      _ = 2 * Real.sqrt (n : ℝ) := by ring
  have hlog_part :
      16 * Real.log (n : ℝ) ≤ 32 * Real.sqrt (n : ℝ) := by
    nlinarith
  have h32_le :
      32 ≤ stackMargin ^ 2 * Real.sqrt (n : ℝ) := by
    have hmul :=
      mul_le_mul_of_nonneg_left hsqrt_threshold (sq_nonneg stackMargin)
    field_simp [hc_sq_pos.ne'] at hmul
    exact hmul
  have hmain :
      32 * Real.sqrt (n : ℝ) ≤ (n : ℝ) * stackMargin ^ 2 := by
    have hmul :=
      mul_le_mul_of_nonneg_right h32_le (Real.sqrt_nonneg (n : ℝ))
    calc
      32 * Real.sqrt (n : ℝ)
          ≤ (stackMargin ^ 2 * Real.sqrt (n : ℝ)) *
              Real.sqrt (n : ℝ) := hmul
      _ = (n : ℝ) * stackMargin ^ 2 := by
            rw [mul_assoc, ← pow_two, Real.sq_sqrt hn_nonneg]
            ring
  exact hlog_part.trans (by simpa [stackMargin] using hmain)

/-- A convenient way to pay the simplified width budget: use half of the
available `sqrt(n log n)` term for the constant and half for `5 log n`. -/
theorem width_simple_budget_of_const_budget {K : ℝ} {n : ℕ}
    (hn : 1 ≤ n)
    (hKlarge : 150 ≤ K * Real.log 2)
    (hconst :
      Real.log 128 + 4 * Real.log 2 ≤
        (K / 30 * Real.log 2) *
          Real.sqrt ((n : ℝ) * Real.log (n : ℝ))) :
    Real.log 128 + 4 * Real.log 2 + 5 * Real.log (n : ℝ) ≤
      (K / 15 * Real.log 2) *
        Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) := by
  have hsqrt_nonneg :
      0 ≤ Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
    Real.sqrt_nonneg _
  have hlog_sqrt := log_le_sqrt_n_log (n := n) hn
  have hcoeff : (5 : ℝ) ≤ K / 30 * Real.log 2 := by
    nlinarith
  have hlog_part :
      5 * Real.log (n : ℝ) ≤
        (K / 30 * Real.log 2) *
          Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) := by
    have hlog_le_sqrt_scaled :
        5 * Real.log (n : ℝ) ≤
          5 * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
      mul_le_mul_of_nonneg_left hlog_sqrt (by norm_num : (0 : ℝ) ≤ 5)
    have hsqrt_scaled_le_budget :
        5 * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) ≤
          (K / 30 * Real.log 2) *
            Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
      mul_le_mul_of_nonneg_right hcoeff hsqrt_nonneg
    exact hlog_le_sqrt_scaled.trans hsqrt_scaled_le_budget
  nlinarith

/-- Monotonicity of the integer sequence `n log n` for `n≥1`, in the only
form needed for cutoff propagation. -/
theorem nat_mul_log_mono_from_one {n0 n : ℕ}
    (hn0_pos : 1 ≤ n0)
    (hn : n0 ≤ n) :
    (n0 : ℝ) * Real.log (n0 : ℝ) ≤
      (n : ℝ) * Real.log (n : ℝ) := by
  have hn0_pos_nat : 0 < n0 := by omega
  have hn0_pos_real : 0 < (n0 : ℝ) := by exact_mod_cast hn0_pos_nat
  have hnreal : (n0 : ℝ) ≤ (n : ℝ) := by exact_mod_cast hn
  have hlog_le : Real.log (n0 : ℝ) ≤ Real.log (n : ℝ) :=
    Real.log_le_log hn0_pos_real hnreal
  have hlog0_nonneg : 0 ≤ Real.log (n0 : ℝ) :=
    Real.log_natCast_nonneg n0
  have hn_nonneg : 0 ≤ (n : ℝ) := by positivity
  exact mul_le_mul hnreal hlog_le hlog0_nonneg hn_nonneg

/-- The coarse `core≥9` square budget propagates from the cutoff because
`n log n` is monotone for `n≥1`. -/
theorem annulus_core_nine_budget_of_cutoff {A : ℝ} {n0 n : ℕ}
    (hn0_pos : 1 ≤ n0) (hn : n0 ≤ n)
    (hcutoff :
      81 ≤ A ^ 2 * (((3 : ℝ) * (n0 : ℝ) / 4) *
        Real.log (n0 : ℝ))) :
    81 ≤ A ^ 2 * (((3 : ℝ) * (n : ℝ) / 4) *
      Real.log (n : ℝ)) := by
  have hmono := nat_mul_log_mono_from_one hn0_pos hn
  have hinner :
      ((3 : ℝ) * (n0 : ℝ) / 4) * Real.log (n0 : ℝ) ≤
        ((3 : ℝ) * (n : ℝ) / 4) * Real.log (n : ℝ) := by
    nlinarith
  have hscaled :=
    mul_le_mul_of_nonneg_left hinner (sq_nonneg A)
  exact hcutoff.trans hscaled

/-- A width constant budget checked at the cutoff propagates to all larger
dimensions. -/
theorem width_const_budget_of_cutoff {K : ℝ} {n0 n : ℕ}
    (hK : 0 ≤ K)
    (hn0_pos : 1 ≤ n0)
    (hn : n0 ≤ n)
    (hcutoff :
      Real.log 128 + 4 * Real.log 2 ≤
        (K / 30 * Real.log 2) *
          Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ))) :
    Real.log 128 + 4 * Real.log 2 ≤
      (K / 30 * Real.log 2) *
        Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) := by
  have hcore := nat_mul_log_mono_from_one hn0_pos hn
  have hsqrt := Real.sqrt_le_sqrt hcore
  have hlog2_nonneg : 0 ≤ Real.log 2 :=
    (Real.log_pos (by norm_num : (1 : ℝ) < 2)).le
  have hcoeff_nonneg : 0 ≤ K / 30 * Real.log 2 := by positivity
  have hmono :
      (K / 30 * Real.log 2) *
          Real.sqrt ((n0 : ℝ) * Real.log (n0 : ℝ)) ≤
        (K / 30 * Real.log 2) *
          Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
    mul_le_mul_of_nonneg_left hsqrt hcoeff_nonneg
  exact hcutoff.trans hmono

/-- Large-`n` sufficient conditions for the residual stack budget.  The first
condition pays for `2 log n`; the second pays for `3 log 2`. -/
theorem stack_linear_budget_of_sqrt_and_const_bounds {n : ℕ}
    (hn : 1 ≤ n)
    (hsqrt :
      4 * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) ≤
        (n : ℝ) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3))
    (hconst :
      12 * Real.log 2 ≤
        (n : ℝ) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3)) :
    2 * Real.log (n : ℝ) + 3 * Real.log 2 ≤
      ((3 : ℝ) * (n : ℝ) / 4) *
        (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
  have hlog_sqrt := log_le_sqrt_n_log (n := n) hn
  have hlog_part :
      2 * Real.log (n : ℝ) ≤
        ((n : ℝ) / 2) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
    have hlog_le_sqrt_scaled :
        2 * Real.log (n : ℝ) ≤
          2 * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
      mul_le_mul_of_nonneg_left hlog_sqrt (by norm_num : (0 : ℝ) ≤ 2)
    have hsqrt_scaled_le_margin :
        2 * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) ≤
          ((n : ℝ) / 2) *
            (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
      nlinarith
    exact hlog_le_sqrt_scaled.trans hsqrt_scaled_le_margin
  have hconst_part :
      3 * Real.log 2 ≤
        ((n : ℝ) / 4) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
    nlinarith
  exact stack_linear_budget_of_split_bounds hlog_part hconst_part

/-- If the stack constant budget holds at the cutoff, then it holds for every
larger dimension because the linear margin is nonnegative. -/
theorem stack_const_budget_of_cutoff {n0 n : ℕ}
    (hn : n0 ≤ n)
    (hcutoff :
      12 * Real.log 2 ≤
        (n0 : ℝ) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3)) :
    12 * Real.log 2 ≤
      (n : ℝ) *
        (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
  have hmargin := stack_linear_margin_nonneg
  have hnreal : (n0 : ℝ) ≤ (n : ℝ) := by exact_mod_cast hn
  have hmono :
      (n0 : ℝ) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) ≤
        (n : ℝ) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) :=
    mul_le_mul_of_nonneg_right hnreal hmargin
  exact hcutoff.trans hmono

/-- Squared sufficient condition for the stack square-root budget.  With
`c = log(4/3)-log(2)/3`, the condition `16 log n≤n c^2` implies
`4 sqrt(n log n)≤n c`. -/
theorem stack_sqrt_budget_of_log_linear_margin_sq {n : ℕ}
    (hlog :
      16 * Real.log (n : ℝ) ≤
        (n : ℝ) *
          (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) ^ 2) :
    4 * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) ≤
      (n : ℝ) *
        (Real.log ((4 : ℝ) / 3) - Real.log 2 / 3) := by
  let c : ℝ := Real.log ((4 : ℝ) / 3) - Real.log 2 / 3
  have hc : 0 ≤ c := by
    simpa [c] using stack_linear_margin_nonneg
  have hn_nonneg : 0 ≤ (n : ℝ) := by positivity
  have hy_nonneg : 0 ≤ (n : ℝ) * c / 4 := by positivity
  have hscaled :
      (n : ℝ) * Real.log (n : ℝ) ≤ ((n : ℝ) * c / 4) ^ 2 := by
    have hbase :
        16 * Real.log (n : ℝ) ≤ (n : ℝ) * c ^ 2 := by
      simpa [c] using hlog
    have hmul :=
      mul_le_mul_of_nonneg_left
        hbase
        (by positivity : 0 ≤ (n : ℝ) / 16)
    have hscaled' :
        (n : ℝ) * Real.log (n : ℝ) ≤
          (n : ℝ) ^ 2 * c ^ 2 * (1 / 16) := by
      ring_nf at hmul ⊢
      exact hmul
    convert hscaled' using 1
    ring
  have hsqrt :
      Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) ≤
        (n : ℝ) * c / 4 := by
    rw [Real.sqrt_le_iff]
    exact ⟨hy_nonneg, hscaled⟩
  calc
    4 * Real.sqrt ((n : ℝ) * Real.log (n : ℝ))
        ≤ 4 * ((n : ℝ) * c / 4) :=
          mul_le_mul_of_nonneg_left hsqrt (by norm_num : (0 : ℝ) ≤ 4)
    _ = (n : ℝ) * c := by ring

/-- Simplified Bernstein/union-bound logarithmic condition.  If the sampled
mean is at most `2t`, then the more legible lower bound
`delta^2 t/(128 B_0)` implies the logarithmic condition used by the
probabilistic-method finish. -/
theorem log_condition_of_mean_upper {A K : ℝ} {n t : ℕ}
    (ht : 0 < t)
    (hmu_pos :
      0 < (sampleCountForDemand A K n t : ℝ) *
        (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ))
    (hmu_upper :
      (sampleCountForDemand A K n t : ℝ) *
        (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ) ≤
          2 * (t : ℝ))
    (hsimple :
      ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
        (loss n) ^ 2 * (t : ℝ) /
          (128 * (2 ^ (rOut A K n - rIn A K n) : ℝ))) :
    ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
      (demandGapForDemand n t) ^ 2 /
        (4 * (2 ^ (rOut A K n - rIn A K n) : ℝ) *
          ((sampleCountForDemand A K n t : ℝ) *
            (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ))) := by
  let B : ℝ := (2 ^ (rOut A K n - rIn A K n) : ℝ)
  let mu : ℝ := (sampleCountForDemand A K n t : ℝ) *
    (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ)
  have hB_pos : 0 < B := by
    dsimp [B]
    positivity
  have ht_pos_real : 0 < (t : ℝ) := by
    exact_mod_cast ht
  have hden_pos : 0 < 4 * B * mu := by
    dsimp [mu, B]
    positivity
  have hmu_upper' : mu ≤ 2 * (t : ℝ) := by
    simpa [mu] using hmu_upper
  have hden_le : 4 * B * mu ≤ 8 * B * (t : ℝ) := by
    have hmul := mul_le_mul_of_nonneg_left hmu_upper' (by positivity : 0 ≤ 4 * B)
    linarith
  have hnum_nonneg : 0 ≤ (demandGapForDemand n t) ^ 2 := sq_nonneg _
  have hfrac_mono :
      (demandGapForDemand n t) ^ 2 / (8 * B * (t : ℝ)) ≤
        (demandGapForDemand n t) ^ 2 / (4 * B * mu) :=
    div_le_div_of_nonneg_left hnum_nonneg hden_pos hden_le
  have hfrac_eq :
      (demandGapForDemand n t) ^ 2 / (8 * B * (t : ℝ)) =
        (loss n) ^ 2 * (t : ℝ) / (128 * B) := by
    dsimp [demandGapForDemand]
    field_simp [hB_pos.ne', ht_pos_real.ne']
    ring
  calc
    ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2
        ≤ (loss n) ^ 2 * (t : ℝ) / (128 * B) := by
          simpa [B] using hsimple
    _ = (demandGapForDemand n t) ^ 2 / (8 * B * (t : ℝ)) := hfrac_eq.symm
    _ ≤ (demandGapForDemand n t) ^ 2 / (4 * B * mu) := hfrac_mono
    _ = (demandGapForDemand n t) ^ 2 /
        (4 * (2 ^ (rOut A K n - rIn A K n) : ℝ) *
          ((sampleCountForDemand A K n t : ℝ) *
            (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ))) := by
          rfl

/-- The sampled annulus mean is at most `2t` once the annulus mean is bounded
by the full weighted mean and the sample-count ceiling is paid for by the
stack-size threshold. -/
theorem sampleCountForDemand_mean_upper_of_annulusMean_upper
    {A K : ℝ} {n t : ℕ}
    (hloss : loss n ≤ 1)
    (hannulus_upper :
      (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ) ≤
        (2 ^ rOut A K n : ℝ) * (((3 : ℝ) / 4) ^ splitA K n))
    (hstack :
      (2 ^ rOut A K n : ℝ) ≤
        (loss n / 2) * (t : ℝ) * (((4 : ℝ) / 3) ^ splitA K n)) :
    (sampleCountForDemand A K n t : ℝ) *
      (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ) ≤
        2 * (t : ℝ) := by
  let delta : ℝ := loss n
  let pow43 : ℝ := (((4 : ℝ) / 3) ^ splitA K n)
  let pow34 : ℝ := (((3 : ℝ) / 4) ^ splitA K n)
  let S : ℝ := (2 ^ rOut A K n : ℝ)
  let mu : ℝ := (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ)
  let x : ℝ := ((1 + delta / 2) * (t : ℝ) * pow43) / S
  have hdelta_nonneg : 0 ≤ delta := by
    dsimp [delta]
    exact loss_nonneg n
  have hdelta_le : delta ≤ 1 := by
    dsimp [delta]
    exact hloss
  have hSpos : 0 < S := by
    dsimp [S]
    positivity
  have hpow_prod : pow43 * pow34 = 1 := by
    dsimp [pow43, pow34]
    rw [← mul_pow]
    norm_num
  have hx_nonneg : 0 ≤ x := by
    dsimp [x]
    positivity
  have hmu_nonneg : 0 ≤ mu := by
    dsimp [mu]
    exact annulusMean_nonneg _ _ _
  have hmu_upper : mu ≤ S * pow34 := by
    simpa [mu, S, pow34] using hannulus_upper
  have hN_le : (sampleCountForDemand A K n t : ℝ) ≤ x + 1 := by
    exact le_of_lt (by
      simpa [sampleCountForDemand, x, delta, S, pow43] using
        Nat.ceil_lt_add_one hx_nonneg)
  have hmain_le :
      (sampleCountForDemand A K n t : ℝ) * mu ≤ (x + 1) * mu :=
    mul_le_mul_of_nonneg_right hN_le hmu_nonneg
  have hxmu_le : x * mu ≤ (1 + delta / 2) * (t : ℝ) := by
    have hmul := mul_le_mul_of_nonneg_left hmu_upper hx_nonneg
    calc
      x * mu ≤ x * (S * pow34) := hmul
      _ = (1 + delta / 2) * (t : ℝ) := by
        dsimp [x]
        field_simp [hSpos.ne']
        calc
          (t : ℝ) * pow43 * pow34 = (t : ℝ) * (pow43 * pow34) := by ring
          _ = (t : ℝ) * 1 := by rw [hpow_prod]
          _ = (t : ℝ) := by ring
  have hmu_slack : mu ≤ delta / 2 * (t : ℝ) := by
    have hstack' : S ≤ delta / 2 * (t : ℝ) * pow43 := by
      simpa [delta, S, pow43] using hstack
    have hpow34_nonneg : 0 ≤ pow34 := by
      dsimp [pow34]
      positivity
    have hmul := mul_le_mul_of_nonneg_right hstack' hpow34_nonneg
    calc
      mu ≤ S * pow34 := hmu_upper
      _ ≤ (delta / 2 * (t : ℝ) * pow43) * pow34 := hmul
      _ = delta / 2 * (t : ℝ) := by
        calc
          delta / 2 * (t : ℝ) * pow43 * pow34 =
              delta / 2 * (t : ℝ) * (pow43 * pow34) := by ring
          _ = delta / 2 * (t : ℝ) * 1 := by rw [hpow_prod]
          _ = delta / 2 * (t : ℝ) := by ring
  calc
    (sampleCountForDemand A K n t : ℝ) * mu ≤ (x + 1) * mu := hmain_le
    _ = x * mu + mu := by ring
    _ ≤ (1 + delta / 2) * (t : ℝ) + delta / 2 * (t : ℝ) :=
      add_le_add hxmu_le hmu_slack
    _ ≤ 2 * (t : ℝ) := by
      have ht_nonneg : 0 ≤ (t : ℝ) := by positivity
      nlinarith

/-- Since the simplified Bernstein exponent is linear in the demand `t`, it
is enough to check it at the smallest allowed demand. -/
theorem logSimple_for_all_demands_of_minPile {A K : ℝ} {n : ℕ}
    (hmin :
      ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
        (loss n) ^ 2 * (minPile (splitM K n) : ℝ) /
          (128 * (2 ^ (rOut A K n - rIn A K n) : ℝ))) :
    ∀ t : ℕ, minPile (splitM K n) ≤ t →
      ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
        (loss n) ^ 2 * (t : ℝ) /
          (128 * (2 ^ (rOut A K n - rIn A K n) : ℝ)) := by
  intro t ht
  let coeff : ℝ := (loss n) ^ 2 /
    (128 * (2 ^ (rOut A K n - rIn A K n) : ℝ))
  have hcoeff_nonneg : 0 ≤ coeff := by
    dsimp [coeff]
    positivity
  have ht_real : (minPile (splitM K n) : ℝ) ≤ (t : ℝ) := by
    exact_mod_cast ht
  have hmono : coeff * (minPile (splitM K n) : ℝ) ≤ coeff * (t : ℝ) :=
    mul_le_mul_of_nonneg_left ht_real hcoeff_nonneg
  have hmin' :
      ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
        coeff * (minPile (splitM K n) : ℝ) := by
    calc
      ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2
          ≤ (loss n) ^ 2 * (minPile (splitM K n) : ℝ) /
              (128 * (2 ^ (rOut A K n - rIn A K n) : ℝ)) := hmin
      _ = coeff * (minPile (splitM K n) : ℝ) := by
          ring
  calc
    ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2
        ≤ coeff * (minPile (splitM K n) : ℝ) := hmin'
    _ ≤ coeff * (t : ℝ) := hmono
    _ = (loss n) ^ 2 * (t : ℝ) /
          (128 * (2 ^ (rOut A K n - rIn A K n) : ℝ)) := by
          ring

/-- It is enough to prove the minimum-demand Bernstein threshold with
`2^(2w)`, where `w` is the annulus half-width, since
`rOut-rIn ≤ 2w`. -/
theorem logMin_of_widthBound {A K : ℝ} {n : ℕ}
    (hwidthLog :
      ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
        (loss n) ^ 2 * (minPile (splitM K n) : ℝ) /
          (128 * (2 ^ (2 * annulusWidth A K n) : ℝ))) :
    ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
      (loss n) ^ 2 * (minPile (splitM K n) : ℝ) /
        (128 * (2 ^ (rOut A K n - rIn A K n) : ℝ)) := by
  have hpow_le : (2 ^ (rOut A K n - rIn A K n) : ℝ) ≤
      (2 ^ (2 * annulusWidth A K n) : ℝ) := by
    exact_mod_cast
      Nat.pow_le_pow_right (by decide : 0 < 2)
        (rOut_sub_rIn_le_two_width (A := A) (K := K) (n := n))
  have hden_le : 128 * (2 ^ (rOut A K n - rIn A K n) : ℝ) ≤
      128 * (2 ^ (2 * annulusWidth A K n) : ℝ) := by
    exact mul_le_mul_of_nonneg_left hpow_le (by norm_num)
  have hden_pos : 0 < 128 * (2 ^ (rOut A K n - rIn A K n) : ℝ) := by
    positivity
  have hnum_nonneg : 0 ≤ (loss n) ^ 2 * (minPile (splitM K n) : ℝ) := by
    positivity
  have hfrac :
      (loss n) ^ 2 * (minPile (splitM K n) : ℝ) /
          (128 * (2 ^ (2 * annulusWidth A K n) : ℝ)) ≤
        (loss n) ^ 2 * (minPile (splitM K n) : ℝ) /
          (128 * (2 ^ (rOut A K n - rIn A K n) : ℝ)) :=
    div_le_div_of_nonneg_left hnum_nonneg hden_pos hden_le
  exact hwidthLog.trans hfrac

/-- Multiplication-form sufficient condition for the Bernstein width
threshold.  This avoids carrying a division in the remaining asymptotic
estimate. -/
theorem logWidth_of_mul_le {A K : ℝ} {n : ℕ}
    (hmul :
      128 * (2 ^ (2 * annulusWidth A K n) : ℝ) *
          (((splitA K n + 1 : ℕ) : ℝ) * Real.log 2) ≤
        (loss n) ^ 2 * (minPile (splitM K n) : ℝ)) :
    ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
      (loss n) ^ 2 * (minPile (splitM K n) : ℝ) /
        (128 * (2 ^ (2 * annulusWidth A K n) : ℝ)) := by
  let denom : ℝ := 128 * (2 ^ (2 * annulusWidth A K n) : ℝ)
  have hden_pos : 0 < denom := by
    dsimp [denom]
    positivity
  rw [le_div_iff₀ hden_pos]
  simpa [denom, mul_assoc, mul_comm, mul_left_comm] using hmul

/-- A lower bound for the `Binomial(n,1/3)` mass of the annulus window is
exactly the annulus-mean lower bound used by the upper-bound recurrence. -/
theorem annulusMean_lower_of_binomialWindowProbThird
    {n rIn rOut : ℕ} {alpha : ℝ}
    (hprob : alpha ≤ binomialWindowProbThird n rIn rOut) :
    alpha * (2 ^ rOut : ℝ) * (((3 : ℝ) / 4) ^ n) ≤
      (annulusMean n rIn rOut : ℝ) := by
  let C : ℝ := (2 ^ rOut : ℝ) * (((3 : ℝ) / 4) ^ n)
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    positivity
  have hmul : C * alpha ≤ C * binomialWindowProbThird n rIn rOut :=
    mul_le_mul_of_nonneg_left hprob hC_nonneg
  calc
    alpha * (2 ^ rOut : ℝ) * (((3 : ℝ) / 4) ^ n)
        = C * alpha := by ring
    _ ≤ C * binomialWindowProbThird n rIn rOut := hmul
    _ = (annulusMean n rIn rOut : ℝ) := by
      rw [annulusMean_eq_fullWeightedMean_mul_binomialWindowProbThird]

/-- The integer fiber multiplier is bounded by a `1+2 n^{-2}` real multiplier
once the additive ceiling error is absorbed by the extra `n^{-2}` slack. -/
theorem costMultiplier_le_one_add_two_loss {K : ℝ} {n : ℕ}
    (hslack : 1 ≤ loss n * (((4 : ℝ) / 3) ^ splitA K n)) :
    (costMultiplier K n : ℝ) ≤
      (1 + 2 * loss n) * (((4 : ℝ) / 3) ^ splitA K n) := by
  let powTerm : ℝ := (((4 : ℝ) / 3) ^ splitA K n)
  have hpow_pos : 0 < powTerm := by
    dsimp [powTerm]
    positivity
  have hloss_nonneg : 0 ≤ loss n := loss_nonneg n
  have htarget_nonneg : 0 ≤ (1 + loss n) * powTerm := by
    positivity
  have hceil_lt :
      (costMultiplier K n : ℝ) < (1 + loss n) * powTerm + 1 := by
    simpa [costMultiplier, powTerm] using Nat.ceil_lt_add_one htarget_nonneg
  have hmid : (1 + loss n) * powTerm + 1 ≤ (1 + 2 * loss n) * powTerm := by
    have hslack' : 1 ≤ loss n * powTerm := by simpa [powTerm] using hslack
    nlinarith
  exact le_of_lt (lt_of_lt_of_le hceil_lt hmid)

/-- Transparent sufficient condition for the ceiling slack: since
`loss n = n^{-2}`, it is enough that `(4/3)^a` dominate `n^2`. -/
theorem ceilingSlack_of_sq_le_pow {K : ℝ} {n : ℕ}
    (hn : 0 < n)
    (hpow : (n : ℝ) ^ 2 ≤ (((4 : ℝ) / 3) ^ splitA K n)) :
    1 ≤ loss n * (((4 : ℝ) / 3) ^ splitA K n) := by
  unfold loss
  have hn_sq_pos : 0 < (n : ℝ) ^ 2 := by positivity
  calc
    1 = ((n : ℝ) ^ 2)⁻¹ * ((n : ℝ) ^ 2) := by
      field_simp [hn_sq_pos.ne']
    _ ≤ ((n : ℝ) ^ 2)⁻¹ * (((4 : ℝ) / 3) ^ splitA K n) :=
      mul_le_mul_of_nonneg_left hpow (by positivity)

/-- It is enough for ceiling slack to prove the still coarser growth estimate
`n^2 ≤ (4/3)^(n/2)`, because the split condition gives `n/2 ≤ a`. -/
theorem ceilingSq_of_pow_half {K : ℝ} {n : ℕ}
    (hhalf : n / 2 ≤ splitA K n)
    (hpow : (n : ℝ) ^ 2 ≤ (((4 : ℝ) / 3) ^ (n / 2))) :
    (n : ℝ) ^ 2 ≤ (((4 : ℝ) / 3) ^ splitA K n) := by
  have hbase : (1 : ℝ) ≤ ((4 : ℝ) / 3) := by norm_num
  exact hpow.trans (pow_le_pow_right₀ hbase hhalf)

/-- Two-step growth estimate used to prove that `(4/3)^(n/2)` eventually
dominates `n^2`. -/
theorem sq_growth_step_for_four_thirds_half (n : ℕ) (hn : 14 ≤ n) :
    ((n + 2 : ℕ) : ℝ) ^ 2 ≤ ((4 : ℝ) / 3) * (n : ℝ) ^ 2 := by
  have hn_real : (14 : ℝ) ≤ n := by exact_mod_cast hn
  norm_num
  nlinarith [sq_nonneg ((n : ℝ) - 6)]

/-- Explicit elementary growth threshold:
for `n≥58`, `(4/3)^(⌊n/2⌋)` dominates `n^2`. -/
theorem sq_le_four_thirds_pow_half_of_ge (n : ℕ) (hn : 58 ≤ n) :
    (n : ℝ) ^ 2 ≤ (((4 : ℝ) / 3) ^ (n / 2)) := by
  induction n using Nat.twoStepInduction with
  | zero => omega
  | one => omega
  | more n ih0 _ih1 =>
      by_cases hnbase : 58 ≤ n
      · have ih := ih0 hnbase
        have hstep := sq_growth_step_for_four_thirds_half n (by omega : 14 ≤ n)
        calc
          ((n + 2 : ℕ) : ℝ) ^ 2 ≤ ((4 : ℝ) / 3) * (n : ℝ) ^ 2 := hstep
          _ ≤ ((4 : ℝ) / 3) * (((4 : ℝ) / 3) ^ (n / 2)) :=
            mul_le_mul_of_nonneg_left ih (by norm_num)
          _ = ((4 : ℝ) / 3) ^ ((n + 2) / 2) := by
            have hdiv : (n + 2) / 2 = n / 2 + 1 := by omega
            rw [hdiv, pow_succ]
            ring
      · have hcases : n = 56 ∨ n = 57 := by omega
        rcases hcases with rfl | rfl <;> norm_num

/-- Log-scale sufficient condition for a Chernoff tail budget.  If
`E ≥ log 16 + 2 log n`, then `16 exp(-E) ≤ n^{-2}`. -/
theorem sixteen_exp_neg_le_loss_of_log_budget {n : ℕ} {E : ℝ}
    (hn : 0 < n)
    (hlog : Real.log 16 + 2 * Real.log (n : ℝ) ≤ E) :
    16 * Real.exp (-E) ≤ loss n := by
  have hn_pos : 0 < (n : ℝ) := by exact_mod_cast hn
  have hn_sq_pos : 0 < (n : ℝ) ^ 2 := by positivity
  have hmul : 16 * ((n : ℝ) ^ 2) ≤ Real.exp E := by
    have hexp := Real.exp_le_exp.mpr hlog
    have heq :
        Real.exp (Real.log 16 + 2 * Real.log (n : ℝ)) =
          16 * ((n : ℝ) ^ 2) := by
      rw [Real.exp_add, Real.exp_log (by norm_num : (0 : ℝ) < 16)]
      rw [show Real.exp (2 * Real.log (n : ℝ)) = (n : ℝ) ^ 2 by
        rw [show 2 * Real.log (n : ℝ) =
            Real.log (n : ℝ) + Real.log (n : ℝ) by ring]
        simp [Real.exp_add, Real.exp_log hn_pos, sq]]
    simpa [heq] using hexp
  have hexp_pos : 0 < Real.exp E := Real.exp_pos E
  have htarget : 16 / Real.exp E ≤ 1 / ((n : ℝ) ^ 2) := by
    rw [div_le_div_iff₀ hexp_pos hn_sq_pos]
    simpa [mul_comm, mul_left_comm, mul_assoc] using hmul
  unfold loss
  calc
    16 * Real.exp (-E) = 16 / Real.exp E := by
      rw [Real.exp_neg]
      ring
    _ ≤ 1 / ((n : ℝ) ^ 2) := htarget
    _ = (((n : ℝ) ^ 2)⁻¹) := by ring

/-- A convenient way to discharge the tail budget: for `n≥2`,
`log 16 + 2 log n ≤ 6 log n`. -/
theorem tail_budget_of_six_log {n : ℕ} {E : ℝ}
    (hn : 2 ≤ n)
    (hE : 6 * Real.log (n : ℝ) ≤ E) :
    Real.log 16 + 2 * Real.log (n : ℝ) ≤ E := by
  have h2_le_n : (2 : ℝ) ≤ n := by exact_mod_cast hn
  have hlog2_le : Real.log 2 ≤ Real.log (n : ℝ) :=
    Real.log_le_log (by norm_num : (0 : ℝ) < 2) h2_le_n
  have hlog16 : Real.log 16 = 4 * Real.log 2 := by
    rw [show (16 : ℝ) = 2 ^ 4 by norm_num]
    rw [Real.log_pow]
    norm_num
  calc
    Real.log 16 + 2 * Real.log (n : ℝ) =
        4 * Real.log 2 + 2 * Real.log (n : ℝ) := by rw [hlog16]
    _ ≤ 6 * Real.log (n : ℝ) := by linarith
    _ ≤ E := hE

/-- Normalized recurrence for the recursively defined integer cost bound after
absorbing the multiplier ceiling into a doubled loss term. -/
theorem normalizedCost_recursiveCostBound_step_of_ceiling
    {K : ℝ} {n0 n : ℕ}
    (hn : n0 ≤ n) (hsmall : splitM K n < n)
    (hslack : 1 ≤ loss n * (((4 : ℝ) / 3) ^ splitA K n)) :
    normalizedCost (recursiveCostBound K n0) n ≤
      (1 + 2 * loss n) *
        normalizedCost (recursiveCostBound K n0) (splitM K n) := by
  unfold normalizedCost
  have hbase_pos : 0 < ((4 : ℝ) / 3) := by norm_num
  have hpow_n_pos : 0 < (((4 : ℝ) / 3) ^ n) := pow_pos hbase_pos n
  have hsplit : splitA K n + splitM K n = n := by
    unfold splitA
    exact Nat.sub_add_cancel (le_of_lt hsmall)
  have hpow_split : (((4 : ℝ) / 3) ^ n) =
      (((4 : ℝ) / 3) ^ splitA K n) *
        (((4 : ℝ) / 3) ^ splitM K n) := by
    rw [← pow_add, hsplit]
  have hmult := costMultiplier_le_one_add_two_loss (K := K) (n := n) hslack
  have hcost :
      (recursiveCostBound K n0 n : ℝ) ≤
        ((1 + 2 * loss n) * (((4 : ℝ) / 3) ^ splitA K n)) *
          (recursiveCostBound K n0 (splitM K n) : ℝ) := by
    rw [recursiveCostBound_step hn hsmall]
    have hprev_nonneg : 0 ≤ (recursiveCostBound K n0 (splitM K n) : ℝ) := by
      positivity
    have hmul := mul_le_mul_of_nonneg_left hmult hprev_nonneg
    simpa [Nat.cast_mul, mul_comm, mul_left_comm, mul_assoc] using hmul
  have hdiv := div_le_div_of_nonneg_right hcost hpow_n_pos.le
  calc
    (recursiveCostBound K n0 n : ℝ) / (((4 : ℝ) / 3) ^ n)
        ≤ (((1 + 2 * loss n) * (((4 : ℝ) / 3) ^ splitA K n)) *
          (recursiveCostBound K n0 (splitM K n) : ℝ)) /
            (((4 : ℝ) / 3) ^ n) := hdiv
    _ = (1 + 2 * loss n) *
          ((recursiveCostBound K n0 (splitM K n) : ℝ) /
            (((4 : ℝ) / 3) ^ splitM K n)) := by
          rw [hpow_split]
          field_simp [pow_ne_zero _ hbase_pos.ne']

/-- Raw-cost form of the normalized recurrence step.  This is the algebraic
translation of
`|D_n| ≤ (1+n^{-2}) |D_m| (4/3)^a`. -/
theorem normalizedCost_step_of_cost_le {K : ℝ} {costBound : ℕ → ℕ} {n : ℕ}
    (hsplit : splitA K n + splitM K n = n)
    (hcostReal :
      (costBound n : ℝ) ≤
        (1 + loss n) * (((4 : ℝ) / 3) ^ splitA K n) *
          (costBound (splitM K n) : ℝ)) :
    normalizedCost costBound n ≤
      (1 + loss n) * normalizedCost costBound (splitM K n) := by
  unfold normalizedCost
  have hbase_pos : 0 < ((4 : ℝ) / 3) := by norm_num
  have hpow_n_pos : 0 < (((4 : ℝ) / 3) ^ n) := pow_pos hbase_pos n
  have hdiv := div_le_div_of_nonneg_right hcostReal hpow_n_pos.le
  have hpow_split : (((4 : ℝ) / 3) ^ n) =
      (((4 : ℝ) / 3) ^ splitA K n) * (((4 : ℝ) / 3) ^ splitM K n) := by
    rw [← pow_add, hsplit]
  calc
    (costBound n : ℝ) / (((4 : ℝ) / 3) ^ n)
        ≤ ((1 + loss n) * (((4 : ℝ) / 3) ^ splitA K n) *
          (costBound (splitM K n) : ℝ)) / (((4 : ℝ) / 3) ^ n) := hdiv
    _ = (1 + loss n) * ((costBound (splitM K n) : ℝ) /
          (((4 : ℝ) / 3) ^ splitM K n)) := by
          rw [hpow_split]
          field_simp [pow_ne_zero _ hbase_pos.ne']

/-- The concrete parameter theorem.  The hypotheses are the remaining
numerical estimates for the paper's chosen schedule.  Everything after those
estimates is now formal: the high-demand construction, product recursion, base
cases, normalized loss control, and final real `C(4/3)^n` upper bound. -/
theorem hasRealUpperBound_of_parameter_conditions
    {K A : ℝ} {n0 : ℕ} {costBound sampleCount : ℕ → ℕ} {B : ℝ}
    (hn0_pos : 0 < n0)
    (hB : 0 ≤ B)
    (hbase_cost :
      ∀ n : ℕ, n < n0 → 2 ^ n * minPile n ≤ costBound n)
    (hbase_norm :
      ∀ n : ℕ, n < n0 → normalizedCost costBound n ≤ B)
    (hquarter :
      ∀ n : ℕ, n0 ≤ n → 4 * splitM K n ≤ n)
    (hgap_pos :
      ∀ n : ℕ, n0 ≤ n → 0 < demandGap K costBound n)
    (hmean :
      ∀ n : ℕ, n0 ≤ n →
        (costBound (splitM K n) : ℝ) + demandGap K costBound n ≤
          (sampleCount n : ℝ) *
            (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ))
    (hlog :
      ∀ n : ℕ, n0 ≤ n →
        ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
          (demandGap K costBound n) ^ 2 /
            (4 * (2 ^ (rOut A K n - rIn A K n) : ℝ) *
              ((sampleCount n : ℝ) *
                (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ))))
    (hfiberCost :
      ∀ n : ℕ, n0 ≤ n →
        sampleCount n * 2 ^ rOut A K n ≤
          minPile (splitM K n) * costMultiplier K n)
    (hcost :
      ∀ n : ℕ, n0 ≤ n →
        costBound (splitM K n) * costMultiplier K n ≤ costBound n)
    (hminExp :
      ∀ n : ℕ, n0 ≤ n → n / 5 ≤ rOut A K n)
    (hnormStep :
      ∀ n : ℕ, n0 ≤ n →
        normalizedCost costBound n ≤
          (1 + loss n) * normalizedCost costBound (splitM K n)) :
    HasRealHypercubePebblingUpperBound (Real.exp (2 * loss n0) * B) := by
  have hupper : HasHypercubePebblingUpperBound costBound :=
    hasHypercubePebblingUpperBound_of_recursive_split_schedule_large_constant_base
      (costBound := costBound) (minPile := minPile)
      (splitA := splitA K) (splitM := splitM K)
      (K := costMultiplier K) (N := sampleCount)
      (rIn := rIn A K) (rOut := rOut A K)
      (gap := demandGap K costBound) (n0 := n0)
      (fun n hn => one_le_minPile n)
      hbase_cost
      (fun n hn => splitA_add_splitM_of_four_mul_le (hquarter n hn))
      (fun n hn => splitM_lt_of_four_mul_le hn0_pos hn (hquarter n hn))
      hgap_pos hmean hlog hfiberCost hcost
      (fun n hn => minPile_le_stackSize_of_exponent_le (hminExp n hn))
  exact hasRealHypercubePebblingUpperBound_of_geometric_normalizedCost_loss
    (costBound := costBound) (next := splitM K) (loss := loss)
    (n0 := n0) (B := B) (q := (1 : ℝ) / 2) (M := loss n0)
    hupper
    loss_nonneg
    hB
    (loss_nonneg n0)
    (by norm_num)
    (by norm_num)
    (fun n hn => splitM_lt_of_four_mul_le hn0_pos hn (hquarter n hn))
    hnormStep
    hbase_norm
    (fun n hn hnext =>
      loss_decay_of_four_mul_le
        (lt_of_lt_of_le hn0_pos hnext) (hquarter n hn))
    (fun n hn => loss_le_of_le hn0_pos hn)

/-- Concrete parameter theorem using the paper-facing variable-demand product
recurrence.  For every recursive dimension `n` and every actual occupied pile
size `t ≥ minPile(splitM n)`, the probabilistic construction on the large
factor solves demand `t` with cost `t * costMultiplier n`.

This is the recurrence matching the proof in the paper.  The remaining
hypotheses are the concrete annulus mean, Bernstein/union-bound, fiber-cost,
integer cost, and normalized-cost estimates. -/
theorem hasRealUpperBound_of_variable_parameter_conditions
    {K A : ℝ} {n0 : ℕ} {costBound : ℕ → ℕ}
    {sampleCount : ℕ → ℕ → ℕ} {B : ℝ}
    (hn0_pos : 0 < n0)
    (hB : 0 ≤ B)
    (hbase_cost :
      ∀ n : ℕ, n < n0 → 2 ^ n * minPile n ≤ costBound n)
    (hbase_norm :
      ∀ n : ℕ, n < n0 → normalizedCost costBound n ≤ B)
    (hquarter :
      ∀ n : ℕ, n0 ≤ n → 4 * splitM K n ≤ n)
    (hmean :
      ∀ n : ℕ, n0 ≤ n →
        ∀ t : ℕ, minPile (splitM K n) ≤ t →
          (t : ℝ) + demandGapForDemand n t ≤
            (sampleCount n t : ℝ) *
              (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ))
    (hlog :
      ∀ n : ℕ, n0 ≤ n →
        ∀ t : ℕ, minPile (splitM K n) ≤ t →
          ((splitA K n + 1 : ℕ) : ℝ) * Real.log 2 ≤
            (demandGapForDemand n t) ^ 2 /
              (4 * (2 ^ (rOut A K n - rIn A K n) : ℝ) *
                ((sampleCount n t : ℝ) *
                  (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ))))
    (hfiberCost :
      ∀ n : ℕ, n0 ≤ n →
        ∀ t : ℕ, minPile (splitM K n) ≤ t →
          sampleCount n t * 2 ^ rOut A K n ≤ t * costMultiplier K n)
    (hcost :
      ∀ n : ℕ, n0 ≤ n →
        costBound (splitM K n) * costMultiplier K n ≤ costBound n)
    (hminExp :
      ∀ n : ℕ, n0 ≤ n → n / 5 ≤ rOut A K n)
    (hnormStep :
      ∀ n : ℕ, n0 ≤ n →
        normalizedCost costBound n ≤
          (1 + loss n) * normalizedCost costBound (splitM K n)) :
    HasRealHypercubePebblingUpperBound (Real.exp (2 * loss n0) * B) := by
  have hupper : HasHypercubePebblingUpperBound costBound :=
    hasHypercubePebblingUpperBound_of_recursive_split_schedule_variable_large_constant_base
      (costBound := costBound) (minPile := minPile)
      (splitA := splitA K) (splitM := splitM K)
      (K := costMultiplier K) (N := sampleCount)
      (rIn := rIn A K) (rOut := rOut A K)
      (gap := fun n t => demandGapForDemand n t) (n0 := n0)
      (fun n hn => one_le_minPile n)
      hbase_cost
      (fun n hn => splitA_add_splitM_of_four_mul_le (hquarter n hn))
      (fun n hn => splitM_lt_of_four_mul_le hn0_pos hn (hquarter n hn))
      (fun n hn t ht => by
        have hn_pos : 0 < n := lt_of_lt_of_le hn0_pos hn
        have ht_pos : 0 < t :=
          lt_of_lt_of_le Nat.zero_lt_one ((one_le_minPile (splitM K n)).trans ht)
        exact demandGapForDemand_pos hn_pos ht_pos)
      hmean hlog hfiberCost hcost
      (fun n hn => minPile_le_stackSize_of_exponent_le (hminExp n hn))
  exact hasRealHypercubePebblingUpperBound_of_geometric_normalizedCost_loss
    (costBound := costBound) (next := splitM K) (loss := loss)
    (n0 := n0) (B := B) (q := (1 : ℝ) / 2) (M := loss n0)
    hupper
    loss_nonneg
    hB
    (loss_nonneg n0)
    (by norm_num)
    (by norm_num)
    (fun n hn => splitM_lt_of_four_mul_le hn0_pos hn (hquarter n hn))
    hnormStep
    hbase_norm
    (fun n hn hnext =>
      loss_decay_of_four_mul_le
        (lt_of_lt_of_le hn0_pos hnext) (hquarter n hn))
    (fun n hn => loss_le_of_le hn0_pos hn)

/-- Same as `hasRealUpperBound_of_parameter_conditions`, but with the
