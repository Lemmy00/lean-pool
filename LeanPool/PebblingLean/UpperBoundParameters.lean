  have hrOut :=
    rOut_real_le_div_three_add_widthCore_add_one_of_A_nonneg
      (A := A) (K := K) (n := n) hA
  have hrOutLog :
      (rOut A K n : ℝ) * Real.log 2 ≤
        (((splitA K n / 3 : ℕ) : ℝ) + annulusWidthCore A K n + 1) *
          Real.log 2 :=
    mul_le_mul_of_nonneg_right hrOut hlog2_nonneg
  linarith

theorem log_splitA_succ_mul_log_two_le_log_n_succ_mul_log_two {K : ℝ} {n : ℕ} :
    Real.log ((((splitA K n + 1 : ℕ) : ℝ) * Real.log 2)) ≤
      Real.log ((((n + 1 : ℕ) : ℝ) * Real.log 2)) := by
  have hlog2_pos : 0 < Real.log 2 :=
    Real.log_pos (by norm_num : (1 : ℝ) < 2)
  have hle_nat : splitA K n + 1 ≤ n + 1 := by
    unfold splitA
    omega
  have hle_real :
      (((splitA K n + 1 : ℕ) : ℝ) * Real.log 2) ≤
        (((n + 1 : ℕ) : ℝ) * Real.log 2) := by
    have hcast : ((splitA K n + 1 : ℕ) : ℝ) ≤ ((n + 1 : ℕ) : ℝ) := by
