import Mathlib.Analysis.Complex.Exponential
import Mathlib.Analysis.Complex.ExponentialBounds
import Mathlib.Analysis.SpecialFunctions.Pow.Real
import Mathlib.Analysis.Real.Sqrt
import LeanPool.PebblingLean.LowerBound
import LeanPool.PebblingLean.UpperBoundLoss

/-!
# Concrete parameter layer for the upper bound

This file starts instantiating the abstract recurrence with the parameter
choices used in the paper:

* the recursive dimension drop `m = ceil(K sqrt(n log n))`;
* the larger factor `a = n - m`;
* the pile-size invariant `2^(n/5)`;
* the loss `n^{-2}`;
* the annulus centered near `a/3`, with width
  `ceil(A sqrt(a log(2 n^2)))`.

The genuinely analytic inputs are still explicit hypotheses: binomial annulus
mean estimates, the Bernstein/union-bound exponent estimate for these concrete
parameters, and the finite collection of threshold inequalities.  The theorem
at the bottom proves that these hypotheses imply the real asymptotic upper
bound.
-/

namespace PebblingLean

namespace Hypercube

namespace PaperParameters

/-- Dimension of the small recursive factor:
`ceil(K sqrt(n log n))`. -/
noncomputable def splitM (K : ℝ) (n : ℕ) : ℕ :=
  ⌈K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ))⌉₊

/-- Dimension of the large factor. -/
noncomputable def splitA (K : ℝ) (n : ℕ) : ℕ :=
  n - splitM K n

/-- The technical occupied-pile invariant used in the recursion. -/
def minPile (n : ℕ) : ℕ :=
  2 ^ (n / 5)

/-- The recursive loss used in the paper, `n^{-2}`.  At `n = 0` this is `0`
under Lean's totalized inverse convention, but all recurrence uses are above a
positive base cutoff. -/
noncomputable def loss (n : ℕ) : ℝ :=
  ((n : ℝ) ^ 2)⁻¹

/-- Integer multiplier for the fiber cost.  This is the ceiling of the
normalized target multiplier `(1+n^{-2})(4/3)^a`. -/
noncomputable def costMultiplier (K : ℝ) (n : ℕ) : ℕ :=
  ⌈(1 + loss n) * (((4 : ℝ) / 3) ^ splitA K n)⌉₊

/-- The recursive integer cost bound generated by the paper's schedule.

Below the finite cutoff `n0` we use the constant distribution with
`minPile n` pebbles at every vertex.  Above the cutoff we recurse to
`splitM K n` and multiply by the integer fiber multiplier.  The fallback branch
is never used once the threshold hypothesis `4 splitM K n ≤ n` is available,
but it keeps the definition total. -/
noncomputable def recursiveCostBound (K : ℝ) (n0 : ℕ) (n : ℕ) : ℕ :=
  if n < n0 then
    2 ^ n * minPile n
  else if h : splitM K n < n then
    recursiveCostBound K n0 (splitM K n) * costMultiplier K n
  else
    2 ^ n * minPile n
termination_by n
decreasing_by exact h

/-- Annulus half-width for the high-demand construction on the `Q_a` factor,
with the paper's choice `delta = n^{-2}` giving `log(2/delta)=log(2 n^2)`. -/
noncomputable def annulusWidth (A K : ℝ) (n : ℕ) : ℕ :=
  ⌈A * Real.sqrt ((splitA K n : ℝ) * Real.log (2 * (n : ℝ) ^ 2))⌉₊

/-- The real expression inside the annulus-width ceiling. -/
noncomputable def annulusWidthCore (A K : ℝ) (n : ℕ) : ℝ :=
  A * Real.sqrt ((splitA K n : ℝ) * Real.log (2 * (n : ℝ) ^ 2))

/-- Inner radius of the annulus in the large factor. -/
noncomputable def rIn (A K : ℝ) (n : ℕ) : ℕ :=
  splitA K n / 3 - annulusWidth A K n

/-- Outer radius of the annulus in the large factor. -/
noncomputable def rOut (A K : ℝ) (n : ℕ) : ℕ :=
  splitA K n / 3 + annulusWidth A K n

theorem rIn_le_rOut {A K : ℝ} {n : ℕ} :
    rIn A K n ≤ rOut A K n := by
  unfold rIn rOut
  omega

theorem splitA_div_three_le_rOut {A K : ℝ} {n : ℕ} :
    splitA K n / 3 ≤ rOut A K n := by
  unfold rOut
  omega

theorem annulusWidthCore_nonneg_of_A_nonneg {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A) :
    0 ≤ annulusWidthCore A K n := by
  unfold annulusWidthCore
  positivity

theorem annulusWidth_real_lt_core_add_one {A K : ℝ} {n : ℕ}
    (hcore : 0 ≤ annulusWidthCore A K n) :
    (annulusWidth A K n : ℝ) < annulusWidthCore A K n + 1 := by
  simpa [annulusWidth, annulusWidthCore] using Nat.ceil_lt_add_one hcore

theorem annulusWidth_real_le_core_add_one {A K : ℝ} {n : ℕ}
    (hcore : 0 ≤ annulusWidthCore A K n) :
    (annulusWidth A K n : ℝ) ≤ annulusWidthCore A K n + 1 :=
  le_of_lt (annulusWidth_real_lt_core_add_one hcore)

/-- The integer annulus width dominates its real core because it is a ceiling. -/
theorem annulusWidthCore_le_width_real {A K : ℝ} {n : ℕ} :
    annulusWidthCore A K n ≤ (annulusWidth A K n : ℝ) := by
  unfold annulusWidth annulusWidthCore
  exact Nat.le_ceil
    (A * Real.sqrt ((splitA K n : ℝ) * Real.log (2 * (n : ℝ) ^ 2)))

theorem annulusWidth_real_ge_of_core_ge {A K : ℝ} {n : ℕ}
    (hcore : 9 ≤ annulusWidthCore A K n) :
    9 ≤ (annulusWidth A K n : ℝ) :=
  hcore.trans annulusWidthCore_le_width_real

theorem annulusWidthCore_sq_le_width_sq_of_A_nonneg {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A) :
    (annulusWidthCore A K n) ^ 2 ≤
      (annulusWidth A K n : ℝ) ^ 2 := by
  have hcore_nonneg :=
    annulusWidthCore_nonneg_of_A_nonneg (A := A) (K := K) (n := n) hA
  have hwidth_nonneg : 0 ≤ (annulusWidth A K n : ℝ) := by positivity
  exact (sq_le_sq₀ hcore_nonneg hwidth_nonneg).mpr
    (annulusWidthCore_le_width_real (A := A) (K := K) (n := n))

theorem chernoff_width_sq_of_core_sq {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A)
    (hcoreSq :
      12 * ((splitA K n : ℝ) + 1) * Real.log (n : ℝ) ≤
        (annulusWidthCore A K n) ^ 2) :
    12 * ((splitA K n : ℝ) + 1) * Real.log (n : ℝ) ≤
      (annulusWidth A K n : ℝ) ^ 2 :=
  hcoreSq.trans (annulusWidthCore_sq_le_width_sq_of_A_nonneg
    (A := A) (K := K) (n := n) hA)

theorem three_width_le_splitA_of_core_bound {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A)
    (hcore :
      3 * (annulusWidthCore A K n + 1) ≤ (splitA K n : ℝ)) :
    3 * annulusWidth A K n ≤ splitA K n := by
  have hcore_nonneg :=
    annulusWidthCore_nonneg_of_A_nonneg (A := A) (K := K) (n := n) hA
  have hwidth_le :
      (annulusWidth A K n : ℝ) ≤ annulusWidthCore A K n + 1 :=
    annulusWidth_real_le_core_add_one hcore_nonneg
  have hreal :
      (3 : ℝ) * (annulusWidth A K n : ℝ) ≤ (splitA K n : ℝ) := by
    have hmul :
        (3 : ℝ) * (annulusWidth A K n : ℝ) ≤
          3 * (annulusWidthCore A K n + 1) :=
      mul_le_mul_of_nonneg_left hwidth_le (by norm_num : (0 : ℝ) ≤ 3)
    exact hmul.trans hcore
  exact_mod_cast hreal

theorem annulusWidth_real_le_core_add_one_of_A_nonneg {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A) :
    (annulusWidth A K n : ℝ) ≤ annulusWidthCore A K n + 1 :=
  annulusWidth_real_le_core_add_one
    (annulusWidthCore_nonneg_of_A_nonneg hA)

theorem rOut_real_le_div_three_add_widthCore_add_one_of_A_nonneg
    {A K : ℝ} {n : ℕ} (hA : 0 ≤ A) :
    (rOut A K n : ℝ) ≤
      ((splitA K n / 3 : ℕ) : ℝ) + annulusWidthCore A K n + 1 := by
  unfold rOut
  rw [Nat.cast_add]
  have hwidth :=
    annulusWidth_real_le_core_add_one_of_A_nonneg
      (A := A) (K := K) (n := n) hA
  linarith

/-- The coarse split condition `4m≤n` already makes the center radius
large enough for the recursive pile invariant `2^(n/5)`. -/
theorem n_div_five_le_splitA_div_three_of_four_mul_le {K : ℝ} {n : ℕ}
    (hquarter : 4 * splitM K n ≤ n) :
    n / 5 ≤ splitA K n / 3 := by
  unfold splitA
  omega

theorem n_div_five_le_rOut_of_four_mul_le {A K : ℝ} {n : ℕ}
    (hquarter : 4 * splitM K n ≤ n) :
    n / 5 ≤ rOut A K n := by
  calc
    n / 5 ≤ splitA K n / 3 :=
      n_div_five_le_splitA_div_three_of_four_mul_le hquarter
    _ ≤ rOut A K n := splitA_div_three_le_rOut

/-- The annulus diameter is at most twice the half-width parameter. -/
theorem rOut_sub_rIn_le_two_width {A K : ℝ} {n : ℕ} :
    rOut A K n - rIn A K n ≤ 2 * annulusWidth A K n := by
  unfold rOut rIn
  omega

/-- Demand-dependent number of random annulus centers used in the high-demand
construction.  The factor `1 + loss n / 2` leaves the other half of the
`loss n` budget to pay for the ceiling. -/
noncomputable def sampleCountForDemand (A K : ℝ) (n t : ℕ) : ℕ :=
  ⌈((1 + loss n / 2) * (t : ℝ) * (((4 : ℝ) / 3) ^ splitA K n)) /
    (2 ^ rOut A K n : ℝ)⌉₊

/-- The gap in the high-demand lemma when the target demand is the current
recursive cost and `delta = n^{-2}`. -/
noncomputable def demandGap (K : ℝ) (costBound : ℕ → ℕ) (n : ℕ) : ℝ :=
  loss n * (costBound (splitM K n) : ℝ) / 4

/-- Demand-dependent gap used by the paper's variable-demand product step:
for demand `t`, the high-demand construction aims for a surplus
`delta*t/4`, with `delta = n^{-2}` at the ambient recursive dimension. -/
noncomputable def demandGapForDemand (n t : ℕ) : ℝ :=
  loss n * (t : ℝ) / 4

theorem recursiveCostBound_base {K : ℝ} {n0 n : ℕ} (hn : n < n0) :
    recursiveCostBound K n0 n = 2 ^ n * minPile n := by
  rw [recursiveCostBound.eq_1]
  simp [hn]

theorem recursiveCostBound_step {K : ℝ} {n0 n : ℕ}
    (hn : n0 ≤ n) (hsmall : splitM K n < n) :
    recursiveCostBound K n0 n =
      recursiveCostBound K n0 (splitM K n) * costMultiplier K n := by
  rw [recursiveCostBound.eq_1]
  have hnot : ¬ n < n0 := by omega
  simp [hnot, hsmall]

theorem recursiveCostBound_base_cost {K : ℝ} {n0 : ℕ} :
    ∀ n : ℕ, n < n0 → 2 ^ n * minPile n ≤ recursiveCostBound K n0 n := by
  intro n hn
  rw [recursiveCostBound_base hn]

theorem one_le_minPile (n : ℕ) : 1 ≤ minPile n := by
  exact Nat.one_le_pow _ _ (by decide : 0 < 2)

theorem loss_nonneg (n : ℕ) : 0 ≤ loss n := by
  unfold loss
  positivity

theorem loss_pos {n : ℕ} (hn : 0 < n) : 0 < loss n := by
  unfold loss
  positivity

theorem loss_le_two_of_pos {n : ℕ} (hn : 0 < n) : loss n ≤ 2 := by
  unfold loss
  have hn1 : (1 : ℝ) ≤ n := by exact_mod_cast hn
  have hsq : (1 : ℝ) ≤ (n : ℝ) ^ 2 := by
    nlinarith [sq_nonneg ((n : ℝ) - 1)]
  have hinv : (((n : ℝ) ^ 2)⁻¹) ≤ 1 :=
    inv_le_one_of_one_le₀ hsq
  nlinarith

theorem loss_le_one_of_pos {n : ℕ} (hn : 0 < n) : loss n ≤ 1 := by
  unfold loss
  have hn1 : (1 : ℝ) ≤ n := by exact_mod_cast hn
  have hsq : (1 : ℝ) ≤ (n : ℝ) ^ 2 := by
    nlinarith [sq_nonneg ((n : ℝ) - 1)]
  exact inv_le_one_of_one_le₀ hsq

theorem demandGapForDemand_pos {n t : ℕ} (hn : 0 < n) (ht : 0 < t) :
    0 < demandGapForDemand n t := by
  unfold demandGapForDemand
  have hloss : 0 < loss n := loss_pos hn
  have ht_real : 0 < (t : ℝ) := by exact_mod_cast ht
  positivity

theorem loss_le_of_le {m n : ℕ} (hm : 0 < m) (hmn : m ≤ n) :
    loss n ≤ loss m := by
  unfold loss
  have hm_pos : 0 < (m : ℝ) := by exact_mod_cast hm
  have hn_pos_nat : 0 < n := lt_of_lt_of_le hm hmn
  have hn_pos : 0 < (n : ℝ) := by exact_mod_cast hn_pos_nat
  have hmn_real : (m : ℝ) ≤ n := by exact_mod_cast hmn
  have hsq : (m : ℝ) ^ 2 ≤ (n : ℝ) ^ 2 := by
    nlinarith [hmn_real, sq_nonneg ((n : ℝ) - m)]
  exact (inv_le_inv₀ (by positivity) (by positivity)).mpr hsq

/-- If the next recursive dimension is at most one quarter of the current
dimension, then the loss drops geometrically.  We use the relaxed ratio `1/2`;
the proof gives much more. -/
theorem loss_decay_of_four_mul_le {m n : ℕ}
    (hm : 0 < m) (hmn : 4 * m ≤ n) :
    loss n ≤ ((1 : ℝ) / 2) * loss m := by
  unfold loss
  have hm_pos : 0 < (m : ℝ) := by exact_mod_cast hm
  have hn_pos_nat : 0 < n := lt_of_lt_of_le (by omega : 0 < 4 * m) hmn
  have h4m_le_n : (4 : ℝ) * m ≤ n := by exact_mod_cast hmn
  have hden : (16 : ℝ) * (m : ℝ) ^ 2 ≤ (n : ℝ) ^ 2 := by
    nlinarith [h4m_le_n, sq_nonneg ((n : ℝ) - (4 : ℝ) * m)]
  have hinv : ((n : ℝ) ^ 2)⁻¹ ≤ ((16 : ℝ) * (m : ℝ) ^ 2)⁻¹ := by
    exact (inv_le_inv₀ (by positivity) (by positivity)).mpr hden
  calc
    ((n : ℝ) ^ 2)⁻¹ ≤ ((16 : ℝ) * (m : ℝ) ^ 2)⁻¹ := hinv
    _ ≤ ((1 : ℝ) / 2) * (((m : ℝ) ^ 2)⁻¹) := by
      field_simp [hm_pos.ne']
      nlinarith [sq_pos_of_pos hm_pos]

theorem splitA_add_splitM_of_four_mul_le {K : ℝ} {n : ℕ}
    (hquarter : 4 * splitM K n ≤ n) :
    splitA K n + splitM K n = n := by
  unfold splitA
  have hmle : splitM K n ≤ n := by omega
  exact Nat.sub_add_cancel hmle

/-- Real form of the identity `a = n-m` under the split condition. -/
theorem splitA_real_eq_sub_of_four_mul_le {K : ℝ} {n : ℕ}
    (hquarter : 4 * splitM K n ≤ n) :
    (splitA K n : ℝ) = (n : ℝ) - (splitM K n : ℝ) := by
  unfold splitA
  have hmle : splitM K n ≤ n := by omega
  exact Nat.cast_sub hmle

/-- The split condition forces the large factor to contain at least
three quarters of the coordinates, as a real inequality. -/
theorem three_quarters_le_splitA_of_four_mul_le {K : ℝ} {n : ℕ}
    (hquarter : 4 * splitM K n ≤ n) :
    (3 : ℝ) * (n : ℝ) / 4 ≤ (splitA K n : ℝ) := by
  have hsplit := splitA_real_eq_sub_of_four_mul_le (K := K) (n := n) hquarter
  have hm : (splitM K n : ℝ) ≤ (n : ℝ) / 4 := by
    have hreal : ((4 * splitM K n : ℕ) : ℝ) ≤ (n : ℝ) := by
      exact_mod_cast hquarter
    norm_num at hreal
    linarith
  rw [hsplit]
  linarith

/-- A weaker but integer-valued form useful for monotonicity of natural powers:
under `4m≤n`, the large factor has dimension at least `n/2`. -/
theorem n_div_two_le_splitA_of_four_mul_le {K : ℝ} {n : ℕ}
    (hquarter : 4 * splitM K n ≤ n) :
    n / 2 ≤ splitA K n := by
  unfold splitA
  omega

theorem splitM_lt_of_four_mul_le {K : ℝ} {n0 n : ℕ}
    (hn0_pos : 0 < n0) (hn : n0 ≤ n)
    (hquarter : 4 * splitM K n ≤ n) :
    splitM K n < n := by
  have hn_pos : 0 < n := lt_of_lt_of_le hn0_pos hn
  omega

/-- Real-valued sufficient condition for the split estimate.  This is the
form produced by asymptotic bounds for `ceil(K sqrt(n log n))`. -/
theorem four_mul_splitM_le_of_real_le_quarter {K : ℝ} {n : ℕ}
    (hreal : (splitM K n : ℝ) ≤ (n : ℝ) / 4) :
    4 * splitM K n ≤ n := by
  have hreal' : ((4 * splitM K n : ℕ) : ℝ) ≤ (n : ℝ) := by
    norm_num
    linarith
  exact_mod_cast hreal'

/-- To prove the real split estimate, it is enough to bound the expression
inside the ceiling with one unit of ceiling overhead. -/
theorem splitM_real_le_quarter_of_ceiling_bound {K : ℝ} {n : ℕ}
    (hnonneg : 0 ≤ K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)))
    (hbound :
      K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) + 1 ≤ (n : ℝ) / 4) :
    (splitM K n : ℝ) ≤ (n : ℝ) / 4 := by
  have hceil_lt :
      (splitM K n : ℝ) <
        K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) + 1 := by
    simpa [splitM] using Nat.ceil_lt_add_one hnonneg
  exact le_trans (le_of_lt hceil_lt) hbound

theorem splitM_core_nonneg_of_K_nonneg {K : ℝ} {n : ℕ}
    (hK : 0 ≤ K) :
    0 ≤ K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
  mul_nonneg hK (Real.sqrt_nonneg _)

/-- A simpler sufficient condition for the ceiling-core split estimate.
For large `n`, proving `K^2 log n ≤ n/64` is enough to force
`K sqrt(n log n)+1 ≤ n/4`. -/
theorem split_core_bound_of_log_le_linear {K : ℝ} {n : ℕ}
    (hK : 0 ≤ K)
    (hn8 : 8 ≤ n)
    (hlogLinear : K ^ 2 * Real.log (n : ℝ) ≤ (n : ℝ) / 64) :
    K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) + 1 ≤
      (n : ℝ) / 4 := by
  have hn_pos_nat : 0 < n := by omega
  have hn_pos : 0 < (n : ℝ) := by exact_mod_cast hn_pos_nat
  have hn_nonneg : 0 ≤ (n : ℝ) := le_of_lt hn_pos
  have hlog_nonneg : 0 ≤ Real.log (n : ℝ) := by
    exact Real.log_nonneg (by exact_mod_cast (by omega : 1 ≤ n))
  have harg_nonneg : 0 ≤ (n : ℝ) * Real.log (n : ℝ) :=
    mul_nonneg hn_nonneg hlog_nonneg
  have hx_nonneg :
      0 ≤ K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) :=
    mul_nonneg hK (Real.sqrt_nonneg _)
  have hsq_left :
      (K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ))) ^ 2 =
        K ^ 2 * ((n : ℝ) * Real.log (n : ℝ)) := by
    rw [mul_pow, Real.sq_sqrt harg_nonneg]
  have hsq_bound :
      (K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ))) ^ 2 ≤
        ((n : ℝ) / 8) ^ 2 := by
    rw [hsq_left]
    calc
      K ^ 2 * ((n : ℝ) * Real.log (n : ℝ)) =
          (n : ℝ) * (K ^ 2 * Real.log (n : ℝ)) := by ring
      _ ≤ (n : ℝ) * ((n : ℝ) / 64) :=
          mul_le_mul_of_nonneg_left hlogLinear hn_nonneg
      _ = ((n : ℝ) / 8) ^ 2 := by ring
  have hn_div8_nonneg : 0 ≤ (n : ℝ) / 8 := by positivity
  have hx_le :
      K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) ≤ (n : ℝ) / 8 :=
    (sq_le_sq₀ hx_nonneg hn_div8_nonneg).mp hsq_bound
  have hone : (1 : ℝ) ≤ (n : ℝ) / 8 := by
    have hn8_real : (8 : ℝ) ≤ n := by exact_mod_cast hn8
    linarith
  linarith

theorem splitM_core_le_real {K : ℝ} {n : ℕ} :
    K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) ≤ (splitM K n : ℝ) := by
  simpa [splitM] using
    Nat.le_ceil (K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)))

/-- A floor-division lower bound for the recursive small dimension.  The
`-1` absorbs the integer division by five. -/
theorem splitM_div_five_real_lower_bound {K : ℝ} {n : ℕ} :
    K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) / 5 - 1 ≤
      ((splitM K n / 5 : ℕ) : ℝ) := by
  have hcore := splitM_core_le_real (K := K) (n := n)
  have hfloor :
      (splitM K n : ℝ) / 5 - 1 ≤ ((splitM K n / 5 : ℕ) : ℝ) := by
    have hnat : splitM K n < 5 * (splitM K n / 5 + 1) :=
      Nat.lt_mul_div_succ (splitM K n) (by decide : 0 < 5)
    have hreal : (splitM K n : ℝ) < (5 * (splitM K n / 5 + 1) : ℕ) := by
      exact_mod_cast hnat
    norm_num at hreal
    linarith
  have hdiv :
      K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) / 5 ≤
        (splitM K n : ℝ) / 5 :=
    div_le_div_of_nonneg_right hcore (by norm_num : (0 : ℝ) ≤ 5)
  linarith

theorem splitA_real_le_n {K : ℝ} {n : ℕ} :
    (splitA K n : ℝ) ≤ (n : ℝ) := by
  have hnat : splitA K n ≤ n := by
    unfold splitA
    exact Nat.sub_le n (splitM K n)
  exact_mod_cast hnat

theorem nat_div_real_le_div (a d : ℕ) (hd : 0 < d) :
    ((a / d : ℕ) : ℝ) ≤ (a : ℝ) / d := by
  have hnat : a / d * d ≤ a := Nat.div_mul_le_self a d
  have hreal : ((a / d * d : ℕ) : ℝ) ≤ (a : ℝ) := by
    exact_mod_cast hnat
  rw [Nat.cast_mul] at hreal
  have hdreal : (0 : ℝ) < d := by exact_mod_cast hd
  rw [le_div_iff₀ hdreal]
  simpa [mul_comm] using hreal

/-- Lower companion to `nat_div_real_le_div`, with one unit of floor slack. -/
theorem div_sub_one_le_nat_div_real (a d : ℕ) (hd : 0 < d) :
    (a : ℝ) / d - 1 ≤ ((a / d : ℕ) : ℝ) := by
  have hnat : a < d * (a / d + 1) := Nat.lt_mul_div_succ a hd
  have hreal : (a : ℝ) < (d * (a / d + 1) : ℕ) := by
    exact_mod_cast hnat
  rw [Nat.cast_mul, Nat.cast_add, Nat.cast_one] at hreal
  have hdreal : (0 : ℝ) < d := by exact_mod_cast hd
  have hdiv : (a : ℝ) / d < ((a / d : ℕ) : ℝ) + 1 := by
    rw [div_lt_iff₀ hdreal]
    linarith
  linarith

/-- If the annulus half-width fits inside the center radius, then the inner
radius is at most `a/3-w` in real notation. -/
theorem rIn_real_le_third_sub_width {A K : ℝ} {n : ℕ}
    (hcenter : annulusWidth A K n ≤ splitA K n / 3) :
    (rIn A K n : ℝ) ≤
      (splitA K n : ℝ) / 3 - (annulusWidth A K n : ℝ) := by
  unfold rIn
  rw [Nat.cast_sub hcenter]
  have hdiv :=
    nat_div_real_le_div (splitA K n) 3 (by decide : 0 < 3)
  linarith

/-- The outer radius is at least `a/3+w-1`; the `1` is the floor slack from
integer division by `3`. -/
theorem third_add_width_sub_one_le_rOut_real {A K : ℝ} {n : ℕ} :
    (splitA K n : ℝ) / 3 + (annulusWidth A K n : ℝ) - 1 ≤
      (rOut A K n : ℝ) := by
  unfold rOut
  rw [Nat.cast_add]
  have hdiv :=
    div_sub_one_le_nat_div_real (splitA K n) 3 (by decide : 0 < 3)
  linarith

theorem splitA_div_three_real_le_n_div_three {K : ℝ} {n : ℕ} :
    ((splitA K n / 3 : ℕ) : ℝ) ≤ (n : ℝ) / 3 := by
  have hdiv_le :
      ((splitA K n / 3 : ℕ) : ℝ) ≤ (splitA K n : ℝ) / 3 :=
    nat_div_real_le_div (splitA K n) 3 (by decide)
  have hsplitA_le_n := splitA_real_le_n (K := K) (n := n)
  linarith

/-- For `n≥2`, `log(2n^2)` is bounded by `3 log n`. -/
theorem log_two_mul_sq_le_three_log {n : ℕ} (hn : 2 ≤ n) :
    Real.log (2 * (n : ℝ) ^ 2) ≤ 3 * Real.log (n : ℝ) := by
  have h2_le_n : (2 : ℝ) ≤ n := by exact_mod_cast hn
  have hlog2_le : Real.log 2 ≤ Real.log (n : ℝ) :=
    Real.log_le_log (by norm_num : (0 : ℝ) < 2) h2_le_n
  calc
    Real.log (2 * (n : ℝ) ^ 2) =
        Real.log 2 + Real.log ((n : ℝ) ^ 2) := by
      rw [Real.log_mul (by norm_num : (2 : ℝ) ≠ 0)
        (by positivity : ((n : ℝ) ^ 2) ≠ 0)]
    _ = Real.log 2 + 2 * Real.log (n : ℝ) := by
      rw [Real.log_pow]
      ring_nf
    _ ≤ 3 * Real.log (n : ℝ) := by linarith

/-- Coarse real upper bound for the annulus-width core. -/
theorem annulusWidthCore_le_sqrt_three_n_log {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A) (hn : 2 ≤ n) :
    annulusWidthCore A K n ≤
      A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) := by
  have hsplit := splitA_real_le_n (K := K) (n := n)
  have hlog := log_two_mul_sq_le_three_log (n := n) hn
  have hlog_nonneg : 0 ≤ Real.log (2 * (n : ℝ) ^ 2) := by
    have hn1 : (1 : ℝ) ≤ n := by exact_mod_cast (by omega : 1 ≤ n)
    have hsq : (1 : ℝ) ≤ (n : ℝ) ^ 2 := by
      nlinarith [sq_nonneg ((n : ℝ) - 1)]
    have hge : (1 : ℝ) ≤ 2 * (n : ℝ) ^ 2 := by nlinarith
    exact Real.log_nonneg hge
  have hn_nonneg : 0 ≤ (n : ℝ) := by positivity
  have harg :
      (splitA K n : ℝ) * Real.log (2 * (n : ℝ) ^ 2) ≤
        3 * (n : ℝ) * Real.log (n : ℝ) := by
    calc
      (splitA K n : ℝ) * Real.log (2 * (n : ℝ) ^ 2)
          ≤ (n : ℝ) * Real.log (2 * (n : ℝ) ^ 2) :=
        mul_le_mul_of_nonneg_right hsplit hlog_nonneg
      _ ≤ (n : ℝ) * (3 * Real.log (n : ℝ)) :=
        mul_le_mul_of_nonneg_left hlog hn_nonneg
      _ = 3 * (n : ℝ) * Real.log (n : ℝ) := by ring
  unfold annulusWidthCore
  exact mul_le_mul_of_nonneg_left (Real.sqrt_le_sqrt harg) hA

/-- For `n≥1`, the logarithm used in the annulus width dominates `log n`. -/
theorem log_le_log_two_mul_sq {n : ℕ} (hn : 1 ≤ n) :
    Real.log (n : ℝ) ≤ Real.log (2 * (n : ℝ) ^ 2) := by
  have hn_pos_nat : 0 < n := by omega
  have hn_pos : 0 < (n : ℝ) := by exact_mod_cast hn_pos_nat
  have hn1 : (1 : ℝ) ≤ n := by exact_mod_cast hn
  have hle : (n : ℝ) ≤ 2 * (n : ℝ) ^ 2 := by
    nlinarith [sq_nonneg ((n : ℝ) - 1)]
  exact Real.log_le_log hn_pos hle

theorem annulusWidthCore_sq_eq {A K : ℝ} {n : ℕ} (hn : 1 ≤ n) :
    (annulusWidthCore A K n) ^ 2 =
      A ^ 2 * ((splitA K n : ℝ) * Real.log (2 * (n : ℝ) ^ 2)) := by
  have hlog_nonneg : 0 ≤ Real.log (2 * (n : ℝ) ^ 2) := by
    have hn1 : (1 : ℝ) ≤ n := by exact_mod_cast hn
    have hsq : (1 : ℝ) ≤ (n : ℝ) ^ 2 := by
      nlinarith [sq_nonneg ((n : ℝ) - 1)]
    have harg : (1 : ℝ) ≤ 2 * (n : ℝ) ^ 2 := by nlinarith
    exact Real.log_nonneg harg
  have harg_nonneg :
      0 ≤ (splitA K n : ℝ) * Real.log (2 * (n : ℝ) ^ 2) :=
    mul_nonneg (by positivity) hlog_nonneg
  unfold annulusWidthCore
  rw [mul_pow, Real.sq_sqrt harg_nonneg]

/-- The real annulus-width core has square at least
`A^2 a log n`, where `a=splitA K n`. -/
theorem annulusWidthCore_sq_ge_splitA_log {A K : ℝ} {n : ℕ}
    (hn : 1 ≤ n) :
    A ^ 2 * ((splitA K n : ℝ) * Real.log (n : ℝ)) ≤
      (annulusWidthCore A K n) ^ 2 := by
  have hlog := log_le_log_two_mul_sq (n := n) hn
  have ha_nonneg : 0 ≤ (splitA K n : ℝ) := by positivity
  have hprod :
      (splitA K n : ℝ) * Real.log (n : ℝ) ≤
        (splitA K n : ℝ) * Real.log (2 * (n : ℝ) ^ 2) :=
    mul_le_mul_of_nonneg_left hlog ha_nonneg
  have hmul := mul_le_mul_of_nonneg_left hprod (sq_nonneg A)
  rw [annulusWidthCore_sq_eq (A := A) (K := K) (n := n) hn]
  exact hmul

/-- A coarse upper estimate sufficient for the center-width condition
`3(core+1)≤a`. -/
theorem three_annulusWidthCore_add_one_le_splitA_of_coarse
    {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A) (hn : 2 ≤ n)
    (ha_lower : (3 : ℝ) * (n : ℝ) / 4 ≤ (splitA K n : ℝ))
    (hcoarse :
      3 * (A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1) ≤
        (3 : ℝ) * (n : ℝ) / 4) :
    3 * (annulusWidthCore A K n + 1) ≤ (splitA K n : ℝ) := by
  have hcore :=
    annulusWidthCore_le_sqrt_three_n_log
      (A := A) (K := K) (n := n) hA hn
  have hleft :
      3 * (annulusWidthCore A K n + 1) ≤
        3 * (A * Real.sqrt (3 * (n : ℝ) * Real.log (n : ℝ)) + 1) := by
    nlinarith
  exact hleft.trans (hcoarse.trans ha_lower)

/-- The coarse square budget for `core≥9` propagates from a lower bound on
`a` and `log(2n^2)≥log n`. -/
theorem annulusWidthCore_ge_nine_of_coarse_sq
    {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A) (hn : 1 ≤ n)
    (ha_lower : (3 : ℝ) * (n : ℝ) / 4 ≤ (splitA K n : ℝ))
    (hbudget :
      81 ≤ A ^ 2 * (((3 : ℝ) * (n : ℝ) / 4) *
        Real.log (n : ℝ))) :
    9 ≤ annulusWidthCore A K n := by
  have hlog_nonneg : 0 ≤ Real.log (n : ℝ) :=
    Real.log_natCast_nonneg n
  have hinner :
      ((3 : ℝ) * (n : ℝ) / 4) * Real.log (n : ℝ) ≤
        (splitA K n : ℝ) * Real.log (n : ℝ) :=
    mul_le_mul_of_nonneg_right ha_lower hlog_nonneg
  have hcoarse :
      A ^ 2 * (((3 : ℝ) * (n : ℝ) / 4) *
        Real.log (n : ℝ)) ≤
        A ^ 2 * ((splitA K n : ℝ) * Real.log (n : ℝ)) :=
    mul_le_mul_of_nonneg_left hinner (sq_nonneg A)
  have hsq :
      (9 : ℝ) ^ 2 ≤ (annulusWidthCore A K n) ^ 2 := by
    norm_num
    exact (hbudget.trans hcoarse).trans
      (annulusWidthCore_sq_ge_splitA_log (A := A) (K := K) (n := n) hn)
  exact (sq_le_sq₀ (by norm_num : (0 : ℝ) ≤ 9)
    (annulusWidthCore_nonneg_of_A_nonneg
      (A := A) (K := K) (n := n) hA)).mp hsq

/-- If `A^2≥16` and the large factor has dimension at least three, then the
core square gives the Chernoff six-log exponent condition. -/
theorem chernoff_core_sq_of_A_sq_ge
    {A K : ℝ} {n : ℕ}
    (hn : 1 ≤ n)
    (ha_three : 3 ≤ (splitA K n : ℝ))
    (hA_sq : 16 ≤ A ^ 2) :
    12 * ((splitA K n : ℝ) + 1) * Real.log (n : ℝ) ≤
      (annulusWidthCore A K n) ^ 2 := by
  let a : ℝ := (splitA K n : ℝ)
  let L : ℝ := Real.log (n : ℝ)
  have hL_nonneg : 0 ≤ L := by
    dsimp [L]
    exact Real.log_natCast_nonneg n
  have ha_nonneg : 0 ≤ a := by
    dsimp [a]
    positivity
  have ha_three' : 3 ≤ a := by
    simpa [a] using ha_three
  have hcoeff : 12 * (a + 1) ≤ 16 * a := by
    nlinarith
  have hleft :
      12 * (a + 1) * L ≤ 16 * a * L := by
    exact mul_le_mul_of_nonneg_right hcoeff hL_nonneg
  have hmid :
      16 * a * L ≤ A ^ 2 * (a * L) := by
    have haL_nonneg : 0 ≤ a * L := mul_nonneg ha_nonneg hL_nonneg
    have hmul := mul_le_mul_of_nonneg_right hA_sq haL_nonneg
    nlinarith
  have hcore :=
    annulusWidthCore_sq_ge_splitA_log
      (A := A) (K := K) (n := n) hn
  calc
    12 * ((splitA K n : ℝ) + 1) * Real.log (n : ℝ)
        = 12 * (a + 1) * L := by rfl
    _ ≤ 16 * a * L := hleft
    _ ≤ A ^ 2 * (a * L) := hmid
    _ = A ^ 2 * ((splitA K n : ℝ) * Real.log (n : ℝ)) := by rfl
    _ ≤ (annulusWidthCore A K n) ^ 2 := hcore

theorem recursiveCostBound_step_cost {K : ℝ} {n0 : ℕ}
    (hn0_pos : 0 < n0)
    (hquarter : ∀ n : ℕ, n0 ≤ n → 4 * splitM K n ≤ n) :
    ∀ n : ℕ, n0 ≤ n →
      recursiveCostBound K n0 (splitM K n) * costMultiplier K n ≤
        recursiveCostBound K n0 n := by
  intro n hn
  have hsmall := splitM_lt_of_four_mul_le hn0_pos hn (hquarter n hn)
  rw [recursiveCostBound_step hn hsmall]

theorem minPile_le_stackSize_of_exponent_le {A K : ℝ} {n : ℕ}
    (h : n / 5 ≤ rOut A K n) :
    minPile n ≤ 2 ^ rOut A K n := by
  exact Nat.pow_le_pow_right (by decide : 0 < 2) h

theorem costMultiplier_lt_add_one {K : ℝ} {n : ℕ}
    (hnonneg : 0 ≤ (1 + loss n) * (((4 : ℝ) / 3) ^ splitA K n)) :
    (costMultiplier K n : ℝ) <
      (1 + loss n) * (((4 : ℝ) / 3) ^ splitA K n) + 1 := by
  simpa [costMultiplier] using Nat.ceil_lt_add_one hnonneg

/-- The sample-count ceiling still fits inside the integer fiber multiplier
once the annulus stack size is at most the reserved half-loss budget. -/
theorem sampleCountForDemand_fiberCost {A K : ℝ} {n t : ℕ}
    (hstack :
      (2 ^ rOut A K n : ℝ) ≤
        (loss n / 2) * (t : ℝ) * (((4 : ℝ) / 3) ^ splitA K n)) :
    sampleCountForDemand A K n t * 2 ^ rOut A K n ≤
      t * costMultiplier K n := by
  let powTerm : ℝ := (((4 : ℝ) / 3) ^ splitA K n)
  let S : ℝ := (2 ^ rOut A K n : ℝ)
  let x : ℝ := ((1 + loss n / 2) * (t : ℝ) * powTerm) / S
  have hSpos : 0 < S := by
    dsimp [S]
    positivity
  have hpow_pos : 0 < powTerm := by
    dsimp [powTerm]
    positivity
  have hloss_nonneg : 0 ≤ loss n := loss_nonneg n
  have hx_nonneg : 0 ≤ x := by
    dsimp [x]
    positivity
  have hceil_lt : (sampleCountForDemand A K n t : ℝ) < x + 1 := by
    simpa [sampleCountForDemand, x, S, powTerm] using Nat.ceil_lt_add_one hx_nonneg
  have hleft_lt : (sampleCountForDemand A K n t : ℝ) * S < (x + 1) * S :=
    mul_lt_mul_of_pos_right hceil_lt hSpos
  have hstack' : S ≤ (loss n / 2) * (t : ℝ) * powTerm := by
    simpa [S, powTerm] using hstack
  have hmid : (x + 1) * S ≤ (1 + loss n) * (t : ℝ) * powTerm := by
    dsimp [x]
    field_simp [hSpos.ne']
    nlinarith [hstack']
  have hcost_target :
      (1 + loss n) * powTerm ≤ (costMultiplier K n : ℝ) := by
    have hle := Nat.le_ceil ((1 + loss n) * powTerm)
    simpa [costMultiplier, powTerm, mul_comm, mul_left_comm, mul_assoc] using hle
  have hright :
      (1 + loss n) * (t : ℝ) * powTerm ≤
        (t * costMultiplier K n : ℝ) := by
    have ht_nonneg : 0 ≤ (t : ℝ) := by positivity
    calc
      (1 + loss n) * (t : ℝ) * powTerm
          = (t : ℝ) * ((1 + loss n) * powTerm) := by ring
      _ ≤ (t : ℝ) * (costMultiplier K n : ℝ) :=
          mul_le_mul_of_nonneg_left hcost_target ht_nonneg
  have hreal :
      (sampleCountForDemand A K n t * 2 ^ rOut A K n : ℝ) ≤
        (t * costMultiplier K n : ℝ) := by
    have hlt :
        (sampleCountForDemand A K n t : ℝ) * S <
          (t * costMultiplier K n : ℝ) :=
      lt_of_lt_of_le hleft_lt (hmid.trans hright)
    exact le_of_lt (by simpa [S] using hlt)
  exact_mod_cast hreal

/-- The concrete sample count gives the required mean surplus once the annulus
mean captures at least a `(1-delta/8)` fraction of the ideal weighted mean.
Here `delta = loss n = n^{-2}`. -/
theorem sampleCountForDemand_mean_of_annulusMean_lower {A K : ℝ} {n t : ℕ}
    (hloss : loss n ≤ 2)
    (hannulus :
      (1 - loss n / 8) * (2 ^ rOut A K n : ℝ) *
          (((3 : ℝ) / 4) ^ splitA K n) ≤
        (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ)) :
    (t : ℝ) + demandGapForDemand n t ≤
      (sampleCountForDemand A K n t : ℝ) *
        (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ) := by
  let delta : ℝ := loss n
  let pow43 : ℝ := (((4 : ℝ) / 3) ^ splitA K n)
  let pow34 : ℝ := (((3 : ℝ) / 4) ^ splitA K n)
  let S : ℝ := (2 ^ rOut A K n : ℝ)
  let mu : ℝ := (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ)
  let lower : ℝ := (1 - delta / 8) * S * pow34
  let x : ℝ := ((1 + delta / 2) * (t : ℝ) * pow43) / S
  have hdelta_nonneg : 0 ≤ delta := by
    dsimp [delta]
    exact loss_nonneg n
  have hdelta_le : delta ≤ 2 := by
    dsimp [delta]
    exact hloss
  have hSpos : 0 < S := by
    dsimp [S]
    positivity
  have hpow43_pos : 0 < pow43 := by
    dsimp [pow43]
    positivity
  have hpow34_pos : 0 < pow34 := by
    dsimp [pow34]
    positivity
  have hlower_nonneg : 0 ≤ lower := by
    dsimp [lower]
    have hfactor : 0 ≤ 1 - delta / 8 := by nlinarith
    positivity
  have hmu_ge : lower ≤ mu := by
    simpa [lower, mu, delta, S, pow34] using hannulus
  have hmu_nonneg : 0 ≤ mu := hlower_nonneg.trans hmu_ge
  have hx_nonneg : 0 ≤ x := by
    dsimp [x]
    positivity
  have hx_le_N : x ≤ (sampleCountForDemand A K n t : ℝ) := by
    simpa [sampleCountForDemand, x, delta, S, pow43] using Nat.le_ceil x
  have htarget_lower : (t : ℝ) + demandGapForDemand n t ≤ x * lower := by
    have hpow_prod : pow43 * pow34 = 1 := by
      dsimp [pow43, pow34]
      rw [← mul_pow]
      norm_num
    have hxlower_eq :
        x * lower = (1 + delta / 2) * (1 - delta / 8) * (t : ℝ) := by
      calc
        x * lower = (((1 + delta / 2) * (t : ℝ) * pow43) / S) *
            ((1 - delta / 8) * S * pow34) := by rfl
        _ = ((1 + delta / 2) * (1 - delta / 8) * (t : ℝ)) *
            (pow43 * pow34) := by
              field_simp [hSpos.ne']
        _ = (1 + delta / 2) * (1 - delta / 8) * (t : ℝ) := by
              simp [hpow_prod]
    rw [hxlower_eq]
    change (t : ℝ) + delta * (t : ℝ) / 4 ≤
      (1 + delta / 2) * (1 - delta / 8) * (t : ℝ)
    have ht_nonneg : 0 ≤ (t : ℝ) := by positivity
    have htwo_minus : 0 ≤ 2 - delta := by nlinarith
    have hprod_nonneg : 0 ≤ (t : ℝ) * delta * (2 - delta) :=
      mul_nonneg (mul_nonneg ht_nonneg hdelta_nonneg) htwo_minus
    nlinarith
  calc
    (t : ℝ) + demandGapForDemand n t ≤ x * lower := htarget_lower
    _ ≤ x * mu := mul_le_mul_of_nonneg_left hmu_ge hx_nonneg
    _ ≤ (sampleCountForDemand A K n t : ℝ) * mu :=
      mul_le_mul_of_nonneg_right hx_le_N hmu_nonneg

/-- To verify the stack-size threshold for all allowed demands, it is enough
to verify it at the smallest allowed demand `minPile(splitM n)`. -/
theorem stack_threshold_for_all_demands_of_minPile {A K : ℝ} {n : ℕ}
    (hmin :
      (2 ^ rOut A K n : ℝ) ≤
        (loss n / 2) * (minPile (splitM K n) : ℝ) *
          (((4 : ℝ) / 3) ^ splitA K n)) :
    ∀ t : ℕ, minPile (splitM K n) ≤ t →
      (2 ^ rOut A K n : ℝ) ≤
        (loss n / 2) * (t : ℝ) * (((4 : ℝ) / 3) ^ splitA K n) := by
  intro t ht
  let coeff : ℝ := (loss n / 2) * (((4 : ℝ) / 3) ^ splitA K n)
  have hloss_nonneg : 0 ≤ loss n := loss_nonneg n
  have hcoeff_nonneg : 0 ≤ coeff := by
    dsimp [coeff]
    positivity
  have ht_real : (minPile (splitM K n) : ℝ) ≤ (t : ℝ) := by
    exact_mod_cast ht
  have hmono : coeff * (minPile (splitM K n) : ℝ) ≤ coeff * (t : ℝ) :=
    mul_le_mul_of_nonneg_left ht_real hcoeff_nonneg
  have hmin' :
      (2 ^ rOut A K n : ℝ) ≤ coeff * (minPile (splitM K n) : ℝ) := by
    calc
      (2 ^ rOut A K n : ℝ)
          ≤ (loss n / 2) * (minPile (splitM K n) : ℝ) *
              (((4 : ℝ) / 3) ^ splitA K n) := hmin
      _ = coeff * (minPile (splitM K n) : ℝ) := by
          ring
  calc
    (2 ^ rOut A K n : ℝ) ≤ coeff * (minPile (splitM K n) : ℝ) := hmin'
    _ ≤ coeff * (t : ℝ) := hmono
    _ = (loss n / 2) * (t : ℝ) * (((4 : ℝ) / 3) ^ splitA K n) := by
      simp [coeff, mul_comm, mul_assoc]

/-- Multiplication-form sufficient condition for the stack-size threshold.
Since `loss n = n^{-2}`, this says the product
`minPile(m)(4/3)^a` has room for `2 n^2` copies of the annulus stack size. -/
theorem stack_threshold_minPile_of_mul_le {A K : ℝ} {n : ℕ}
    (hn : 0 < n)
    (hmul :
      2 * ((n : ℝ) ^ 2) * (2 ^ rOut A K n : ℝ) ≤
        (minPile (splitM K n) : ℝ) * (((4 : ℝ) / 3) ^ splitA K n)) :
    (2 ^ rOut A K n : ℝ) ≤
      (loss n / 2) * (minPile (splitM K n) : ℝ) *
        (((4 : ℝ) / 3) ^ splitA K n) := by
  let S : ℝ := (2 ^ rOut A K n : ℝ)
  let M : ℝ := (minPile (splitM K n) : ℝ) * (((4 : ℝ) / 3) ^ splitA K n)
  have hn_sq_pos : 0 < (n : ℝ) ^ 2 := by positivity
  have hden_pos : 0 < 2 * ((n : ℝ) ^ 2) := by positivity
  have hdiv : S ≤ M / (2 * ((n : ℝ) ^ 2)) := by
    rw [le_div_iff₀ hden_pos]
    simpa [S, M, mul_assoc, mul_comm, mul_left_comm] using hmul
  calc
    (2 ^ rOut A K n : ℝ) = S := rfl
    _ ≤ M / (2 * ((n : ℝ) ^ 2)) := hdiv
    _ = (loss n / 2) * (minPile (splitM K n) : ℝ) *
        (((4 : ℝ) / 3) ^ splitA K n) := by
          unfold loss
          field_simp [hn_sq_pos.ne']
          ring

/-- Logarithmic sufficient condition for the multiplication-form stack
threshold.  This rewrites
`2 n^2 2^rOut ≤ 2^(m/5) (4/3)^a` as a comparison of logarithms. -/
theorem stack_mul_le_of_log_budget {A K : ℝ} {n : ℕ}
    (hn : 0 < n)
    (hlog :
      Real.log 2 + 2 * Real.log (n : ℝ) +
          (rOut A K n : ℝ) * Real.log 2 ≤
        ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2 +
          (splitA K n : ℝ) * Real.log ((4 : ℝ) / 3)) :
    2 * ((n : ℝ) ^ 2) * (2 ^ rOut A K n : ℝ) ≤
      (minPile (splitM K n) : ℝ) *
        (((4 : ℝ) / 3) ^ splitA K n) := by
  let L : ℝ := 2 * ((n : ℝ) ^ 2) * (2 ^ rOut A K n : ℝ)
  let R : ℝ :=
    (minPile (splitM K n) : ℝ) * (((4 : ℝ) / 3) ^ splitA K n)
  have hL_pos : 0 < L := by
    dsimp [L]
    positivity
  have hR_pos : 0 < R := by
    dsimp [R, minPile]
    positivity
  have hlogL :
      Real.log L =
        Real.log 2 + 2 * Real.log (n : ℝ) +
          (rOut A K n : ℝ) * Real.log 2 := by
    dsimp [L]
    rw [show 2 * (n : ℝ) ^ 2 * (2 ^ rOut A K n : ℝ) =
        2 * (((n : ℝ) ^ 2) * (2 ^ rOut A K n : ℝ)) by ring]
    rw [Real.log_mul (by norm_num : (2 : ℝ) ≠ 0)
      (by positivity : ((n : ℝ) ^ 2) * (2 ^ rOut A K n : ℝ) ≠ 0)]
    rw [Real.log_mul (by positivity : ((n : ℝ) ^ 2 : ℝ) ≠ 0)
      (by positivity : (2 ^ rOut A K n : ℝ) ≠ 0)]
    rw [Real.log_pow, Real.log_pow]
    ring
  have hlogR :
      Real.log R =
        ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2 +
          (splitA K n : ℝ) * Real.log ((4 : ℝ) / 3) := by
    dsimp [R, minPile]
    rw [Real.log_mul
      (by positivity : ((2 ^ (splitM K n / 5) : ℕ) : ℝ) ≠ 0)
      (by positivity : (((4 : ℝ) / 3) ^ splitA K n) ≠ 0)]
    rw [Nat.cast_pow]
    rw [Real.log_pow, Real.log_pow]
    ring_nf
  have hlogLR : Real.log L ≤ Real.log R := by
    rw [hlogL, hlogR]
    exact hlog
  exact (Real.log_le_log_iff hL_pos hR_pos).mp hlogLR

/-- Logarithmic sufficient condition for the multiplication-form Bernstein
width threshold.  This is the log form of
`128 * 2^(2w) * ((a+1)log 2) ≤ loss(n)^2 * 2^(m/5)`. -/
theorem bernstein_width_mul_le_of_log_budget {A K : ℝ} {n : ℕ}
    (hn : 0 < n)
    (hlog :
      Real.log 128 + ((2 * annulusWidth A K n : ℕ) : ℝ) * Real.log 2 +
          Real.log ((((splitA K n + 1 : ℕ) : ℝ) * Real.log 2)) ≤
        -4 * Real.log (n : ℝ) +
          ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2) :
    128 * (2 ^ (2 * annulusWidth A K n) : ℝ) *
        (((splitA K n + 1 : ℕ) : ℝ) * Real.log 2) ≤
      (loss n) ^ 2 * (minPile (splitM K n) : ℝ) := by
  let C : ℝ := (((splitA K n + 1 : ℕ) : ℝ) * Real.log 2)
  let L : ℝ := 128 * (2 ^ (2 * annulusWidth A K n) : ℝ) * C
  let R : ℝ := (loss n) ^ 2 * (minPile (splitM K n) : ℝ)
  have hlog2_pos : 0 < Real.log 2 :=
    Real.log_pos (by norm_num : (1 : ℝ) < 2)
  have hC_pos : 0 < C := by
    dsimp [C]
    positivity
  have hL_pos : 0 < L := by
    dsimp [L, C]
    positivity
  have hR_pos : 0 < R := by
    dsimp [R, loss, minPile]
    positivity
  have hlogL :
      Real.log L =
        Real.log 128 + ((2 * annulusWidth A K n : ℕ) : ℝ) * Real.log 2 +
          Real.log C := by
    dsimp [L]
    rw [show 128 * (2 ^ (2 * annulusWidth A K n) : ℝ) * C =
        128 * ((2 ^ (2 * annulusWidth A K n) : ℝ) * C) by ring]
    rw [Real.log_mul (by norm_num : (128 : ℝ) ≠ 0)
      (by positivity : (2 ^ (2 * annulusWidth A K n) : ℝ) * C ≠ 0)]
    rw [Real.log_mul
      (by positivity : (2 ^ (2 * annulusWidth A K n) : ℝ) ≠ 0)
      (by positivity : C ≠ 0)]
    rw [Real.log_pow]
    ring_nf
  have hlogR :
      Real.log R =
        -4 * Real.log (n : ℝ) +
          ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2 := by
    dsimp [R, loss, minPile]
    rw [Real.log_mul
      (by positivity : ((((n : ℝ) ^ 2)⁻¹) ^ 2) ≠ 0)
      (by positivity : ((2 ^ (splitM K n / 5) : ℕ) : ℝ) ≠ 0)]
    rw [Real.log_pow]
    rw [Real.log_inv]
    rw [Real.log_pow]
    rw [Nat.cast_pow]
    rw [Real.log_pow]
    ring_nf
  have hlogLR : Real.log L ≤ Real.log R := by
    rw [hlogL, hlogR]
    simpa [C] using hlog
  exact (Real.log_le_log_iff hL_pos hR_pos).mp hlogLR

/-- The Bernstein-width log budget can be proved using the real width core
with one unit of ceiling overhead. -/
theorem bernstein_width_log_budget_of_core_budget {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A)
    (hcoreBudget :
      Real.log 128 + (2 * (annulusWidthCore A K n + 1)) * Real.log 2 +
          Real.log ((((splitA K n + 1 : ℕ) : ℝ) * Real.log 2)) ≤
        -4 * Real.log (n : ℝ) +
          ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2) :
    Real.log 128 + ((2 * annulusWidth A K n : ℕ) : ℝ) * Real.log 2 +
        Real.log ((((splitA K n + 1 : ℕ) : ℝ) * Real.log 2)) ≤
      -4 * Real.log (n : ℝ) +
        ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2 := by
  have hlog2_nonneg : 0 ≤ Real.log 2 :=
    (Real.log_pos (by norm_num : (1 : ℝ) < 2)).le
  have hwidth :=
    annulusWidth_real_le_core_add_one_of_A_nonneg
      (A := A) (K := K) (n := n) hA
  have hwidth2 :
      ((2 * annulusWidth A K n : ℕ) : ℝ) ≤
        2 * (annulusWidthCore A K n + 1) := by
    norm_num
    linarith
  have hwidthLog :
      ((2 * annulusWidth A K n : ℕ) : ℝ) * Real.log 2 ≤
        (2 * (annulusWidthCore A K n + 1)) * Real.log 2 :=
    mul_le_mul_of_nonneg_right hwidth2 hlog2_nonneg
  linarith

/-- The stack log budget can be proved using the real width core with one unit
of ceiling overhead in the outer radius. -/
theorem stack_log_budget_of_core_budget {A K : ℝ} {n : ℕ}
    (hA : 0 ≤ A)
    (hcoreBudget :
      Real.log 2 + 2 * Real.log (n : ℝ) +
          (((splitA K n / 3 : ℕ) : ℝ) + annulusWidthCore A K n + 1) *
            Real.log 2 ≤
        ((splitM K n / 5 : ℕ) : ℝ) * Real.log 2 +
