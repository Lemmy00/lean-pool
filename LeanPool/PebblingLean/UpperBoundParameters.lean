  hasRealUpperBound_of_recursiveCostBound_variable_conditions
    (K := K) (A := A) (n0 := n0)
    (sampleCount := sampleCountForDemand A K) (B := B)
    hn0_pos hB hbase_norm hquarter hmean hlog
    (fun n hn t ht => sampleCountForDemand_fiberCost (hstack n hn t ht))
    hminExp hcostReal

/-- Fully integer-recursive concrete-sample wrapper with ceiling overhead
absorbed into the loss bookkeeping.  Compared with
`hasRealUpperBound_of_recursiveCostBound_concreteSample_conditions`, this
replaces the exact real recurrence hypothesis by the concrete threshold
`1 ≤ n^{-2}(4/3)^a`, and consequently uses the harmless doubled loss
`1+2n^{-2}` in the final recurrence. -/
theorem hasRealUpperBound_of_recursiveCostBound_concreteSample_ceiling_conditions
    {K A : ℝ} {n0 : ℕ} {B : ℝ}
    (hn0_pos : 0 < n0)
    (hB : 0 ≤ B)
    (hbase_norm :
      ∀ n : ℕ, n < n0 → normalizedCost (recursiveCostBound K n0) n ≤ B)
    (hquarter :
      ∀ n : ℕ, n0 ≤ n → 4 * splitM K n ≤ n)
    (hmean :
      ∀ n : ℕ, n0 ≤ n →
        ∀ t : ℕ, minPile (splitM K n) ≤ t →
          (t : ℝ) + demandGapForDemand n t ≤
            (sampleCountForDemand A K n t : ℝ) *
              (annulusMean (splitA K n) (rIn A K n) (rOut A K n) : ℝ))
    (hlog :
      ∀ n : ℕ, n0 ≤ n →
        ∀ t : ℕ, minPile (splitM K n) ≤ t →
