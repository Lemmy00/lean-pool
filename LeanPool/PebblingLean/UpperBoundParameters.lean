    (lamLeft := annulusChernoffLambda A K)
    (lamRight := annulusChernoffLambda A K)
    hn0_pos
    hsplitReal
    (fun n _hn => annulusChernoffLambda_nonneg A K n)
    (fun n _hn => annulusChernoffLambda_nonneg A K n)
    hleftMul
    hrightMul
    hlogWidthMul
    hstackMul
    hceilHalf

