  have hcore := splitM_div_five_real_lower_bound (K := K) (n := n)
  have hrhs :
      -4 * Real.log (n : ℝ) +
          (K * Real.sqrt ((n : ℝ) * Real.log (n : ℝ)) / 5 - 1) *
